#!/usr/bin/env bash
# kilo-docker — Wrapper script for running Kilo in a Docker container.
#
# Usage: kilo-docker [--once] [command] [args...]
# See:   kilo-docker help
#
set -euo pipefail

export PATH="/usr/local/bin:/usr/bin:/bin${PATH:+:$PATH}"

readonly IMAGE="ghcr.io/mbabic84/kilo-docker:latest"
readonly DATA_VOLUME="kilo-data-$(whoami)"
readonly TOKEN_FILE="/home/kilo/.local/share/kilo/.tokens.env"

# --- Helper functions --------------------------------------------------------

confirm() {
    local prompt="$1"
    local response=""
    echo -n "$prompt" >&2
    if [ -t 2 ]; then
        read -r response </dev/tty || response="n"
    else
        response="n"
        echo "n (no TTY)" >&2
    fi
    [[ "${response,,}" == "y" ]]
}

# --- Parse --once flag ------------------------------------------------------

ONCE=0
FILTERED_ARGS=()
for arg in "$@"; do
    if [ "$arg" = "--once" ]; then
        ONCE=1
    else
        FILTERED_ARGS+=("$arg")
    fi
done
# Replace positional parameters with filtered args
set -- "${FILTERED_ARGS[@]}"

# --- Docker daemon check ---------------------------------------------------

if ! docker info >/dev/null 2>&1; then
    echo "Error: Docker daemon is not running." >&2
    exit 1
fi

# --- Handle "init" argument ------------------------------------------------

if [ "${1:-}" = "init" ]; then
    if docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        if confirm "Remove volume '${DATA_VOLUME}' and reset all configuration? [y/N]: "; then
            docker volume rm "$DATA_VOLUME" >/dev/null
            echo "Volume removed. You will be prompted for tokens on next run." >&2
        fi
    else
        echo "No existing volume found." >&2
    fi
    exit 0
fi

# --- Handle "update" argument ----------------------------------------------

if [ "${1:-}" = "update" ]; then
    docker pull "$IMAGE"
    exit 0
fi

# --- Handle "cleanup" argument ----------------------------------------------

if [ "${1:-}" = "cleanup" ]; then
    if ! confirm "Remove volume, containers, and image for kilo-docker? [y/N]: "; then
        echo "Aborted." >&2
        exit 0
    fi

    CONTAINERS=$(docker ps -a --filter "ancestor=${IMAGE}" -q 2>/dev/null || true)
    if [ -n "$CONTAINERS" ]; then
        echo "Removing containers..." >&2
        echo "$CONTAINERS" | xargs docker rm -f >/dev/null 2>&1 || true
    fi

    if docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        echo "Removing volume '${DATA_VOLUME}'..." >&2
        docker volume rm "$DATA_VOLUME" >/dev/null
    fi

    if docker image inspect "$IMAGE" >/dev/null 2>&1; then
        echo "Removing image '${IMAGE}'..." >&2
        docker rmi "$IMAGE" >/dev/null
    fi

    echo "Cleanup complete." >&2
    exit 0
fi

# --- Handle "help" argument ------------------------------------------------

if [ "${1:-}" = "help" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    cat >&2 <<'EOF'
Usage: kilo-docker [--once] [command] [args...]

Commands:
  (no command)      Start Kilo in interactive mode
  run "prompt"      Run Kilo in autonomous mode with a prompt
  init              Reset configuration (remove volume)
  cleanup           Remove volume, containers, and image
  update            Pull the latest Docker image
  help              Show this help message

Options:
  --once            Run a one-time session without persisting data (no volume)

Examples:
  kilo-docker                         # interactive mode
  kilo-docker run "fix build errors"  # autonomous mode
  kilo-docker --once                  # one-time interactive session
  kilo-docker --once run "prompt"     # one-time autonomous session
  kilo-docker init                    # reset configuration
  kilo-docker cleanup                 # remove volume, containers, image
  kilo-docker update                  # pull latest image
EOF
    exit 0
fi

# --- Read/load tokens -------------------------------------------------------

TOKEN_1=""
TOKEN_2=""

if [ "$ONCE" -eq 0 ]; then
    EXISTING=""
    if docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        EXISTING=$(docker run --rm --entrypoint "" \
            -v "${DATA_VOLUME}:/home/kilo/.local/share/kilo" \
            "$IMAGE" \
            cat "$TOKEN_FILE" 2>/dev/null || true)
    fi

    if [ -n "$EXISTING" ]; then
        TOKEN_1=$(echo "$EXISTING" | grep '^KMCP_TOKEN_1=' | cut -d= -f2- || true)
        TOKEN_2=$(echo "$EXISTING" | grep '^KMCP_TOKEN_2=' | cut -d= -f2- || true)
    fi
fi

if [ -z "$TOKEN_1" ] && [ -z "$TOKEN_2" ] && [ "$ONCE" -eq 0 ]; then
    echo "First-time setup: Enter API tokens for remote MCP servers." >&2
    echo "Leave empty to skip a server." >&2
    echo >&2

    if [ -t 2 ]; then
        echo -n "Context7 API token: " >&2
        read -s -r TOKEN_1 </dev/tty || true
        echo >&2

        echo -n "Ainstruct API token: " >&2
        read -s -r TOKEN_2 </dev/tty || true
        echo >&2
    else
        echo "No TTY available. Tokens must be set manually in the volume." >&2
    fi

    if [ -n "$TOKEN_1" ] || [ -n "$TOKEN_2" ]; then
        printf 'KMCP_TOKEN_1=%s\nKMCP_TOKEN_2=%s\n' "$TOKEN_1" "$TOKEN_2" | \
            docker run --rm -i --entrypoint "" \
                -v "${DATA_VOLUME}:/home/kilo/.local/share/kilo" \
                "$IMAGE" \
                sh -c "mkdir -p \"\$(dirname '${TOKEN_FILE}')\" && cat > '${TOKEN_FILE}'"
    fi
fi

# --- Build docker run args -------------------------------------------------

DOCKER_ARGS=(
    --rm
    -e "PUID=$(id -u)"
    -e "PGID=$(id -g)"
    -v "$(pwd):/workspace"
    -w /workspace
)

if [ "$ONCE" -eq 0 ]; then
    DOCKER_ARGS+=(-v "${DATA_VOLUME}:/home/kilo/.local/share/kilo")
fi

if [ -n "$TOKEN_1" ]; then
    DOCKER_ARGS+=(-e "CONTEXT7_TOKEN=${TOKEN_1}")
fi

if [ -n "$TOKEN_2" ]; then
    DOCKER_ARGS+=(-e "AINSTRUCT_TOKEN=${TOKEN_2}")
fi

# Pass terminal capability variables
for var in TERM COLORTERM LANG LC_ALL; do
    if [ -n "${!var:-}" ]; then
        DOCKER_ARGS+=(-e "${var}=${!var}")
    fi
done

# --- Run --------------------------------------------------------------------

if [ $# -gt 0 ]; then
    if [ -t 0 ]; then
        exec docker run -t "${DOCKER_ARGS[@]}" "$IMAGE" "$@"
    else
        exec docker run "${DOCKER_ARGS[@]}" "$IMAGE" "$@"
    fi
else
    if [ -t 0 ]; then
        exec docker run -it "${DOCKER_ARGS[@]}" "$IMAGE"
    else
        exec docker run -i "${DOCKER_ARGS[@]}" "$IMAGE"
    fi
fi
