#!/usr/bin/env bash
# kilo-docker — Wrapper script for running Kilo in a Docker container.
#
# Usage: kilo-docker [--once] [--password] [--playwright] [--docker] [--zellij] [--network <name>] [command] [args...]
#        kilo-docker sessions [name|index]
# See:   kilo-docker help
#
set -euo pipefail

export PATH="/usr/local/bin:/usr/bin:/bin${PATH:+:$PATH}"

readonly REPO="ghcr.io/mbabic84/kilo-docker"
readonly GITHUB_RAW="https://raw.githubusercontent.com/mbabic84/kilo-docker/main/scripts/kilo-docker"
readonly KILO_HOME="/home/kilo-t8x3m7kp"
readonly TOKEN_FILE="${KILO_HOME}/.local/share/kilo/.tokens.env"
readonly ENCRYPTED_TOKEN_FILE="${KILO_HOME}/.local/share/kilo/.tokens.env.enc"
readonly INSTALL_DIR="$HOME/.local/bin"
readonly INSTALL_TARGET="${INSTALL_DIR}/kilo-docker"
readonly KD_AINSTRUCT_API_URL="https://ainstruct-dev.kralicinora.cz/api/v1"

# --- Helper functions --------------------------------------------------------

confirm() {
    local prompt="$1"
    local response=""
    echo -n "$prompt" >&2
    if [ -t 2 ]; then
        read -r response </dev/tty || response="n"
    else
        response="n"
        echo "n (no TTY)" >&2
    fi
    [[ "${response,,}" == "y" ]]
}

prompt_password() {
    local skip_confirm="${1:-}"
    local password=""
    while true; do
        echo -n "Password: " >&2
        read -s -r password </dev/tty || { echo >&2; echo "Error: Failed to read password." >&2; exit 1; }
        echo >&2

        if [ -z "$password" ]; then
            echo "Password cannot be empty." >&2
            continue
        fi

        if [ ${#password} -lt 4 ]; then
            echo "Password must be at least 4 characters." >&2
            continue
        fi

        if [ "$skip_confirm" = "skip_confirm" ]; then
            VOLUME_PASSWORD="$password"
            return
        fi

        echo -n "Confirm: " >&2
        local confirm_pw=""
        read -s -r confirm_pw </dev/tty || { echo >&2; echo "Error: Failed to read password." >&2; exit 1; }
        echo >&2

        if [ "$password" = "$confirm_pw" ]; then
            VOLUME_PASSWORD="$password"
            return
        fi
        echo "Passwords do not match. Try again." >&2
        echo >&2
    done
}

confirm_password() {
    local confirm_pw=""
    echo -n "Confirm: " >&2
    read -s -r confirm_pw </dev/tty || { echo >&2; echo "Error: Failed to read password." >&2; exit 1; }
    echo >&2

    if [ "$confirm_pw" = "$VOLUME_PASSWORD" ]; then
        return
    fi

    echo "Passwords do not match. Re-enter password." >&2
    echo >&2
    prompt_password
    derive_volume_name
}

derive_volume_name() {
    local hash
    hash=$(printf '%s' "$VOLUME_PASSWORD" | sha256sum | cut -c1-12)
    DATA_VOLUME="kilo-${hash}"
}

reset_terminal() {
    # Restore terminal state after docker attach/start hijacks the PTY.
    # Drain leftover stdin bytes (e.g. Ctrl+P Ctrl+Q from docker detach)
    # so the shell doesn't interpret them as input.
    # Operate on /dev/tty directly — not the script's inherited stdin —
    # because stty and dd need the real terminal device to take effect
    # for the parent shell that resumes after this script exits.
    if [ -t 0 ]; then
        dd bs=1 count=256 iflag=nonblock of=/dev/null </dev/tty 2>/dev/null || true
        stty sane </dev/tty 2>/dev/null || true
        stty echo </dev/tty 2>/dev/null || true
        printf '\033c' >/dev/tty 2>/dev/null || true
    fi
}

encrypt_tokens() {
    local token1="$1" token2="$2"
    printf 'KD_CONTEXT7_TOKEN=%s\nKD_AINSTRUCT_TOKEN=%s\n' "$token1" "$token2" | \
        openssl enc -aes-256-cbc -salt -pbkdf2 -pass "pass:${VOLUME_PASSWORD}" -out /dev/stdout 2>/dev/null | \
        docker run --rm -i --entrypoint "" \
            -v "${DATA_VOLUME}:${KILO_HOME}" \
            "$IMAGE" \
            sh -c "mkdir -p \"\$(dirname '${ENCRYPTED_TOKEN_FILE}')\" && cat > '${ENCRYPTED_TOKEN_FILE}' && chmod 600 '${ENCRYPTED_TOKEN_FILE}'"
}

decrypt_tokens() {
    local decrypted
    decrypted=$(docker run --rm --entrypoint "" \
        -v "${DATA_VOLUME}:${KILO_HOME}" \
        "$IMAGE" \
        cat "${ENCRYPTED_TOKEN_FILE}" 2>/dev/null | \
        openssl enc -d -aes-256-cbc -pbkdf2 -pass "pass:${VOLUME_PASSWORD}" 2>/dev/null) || return 1
    echo "$decrypted"
}

prompt_missing_tokens() {
    local token1="" token2=""

    echo "First-time setup: Enter API tokens for remote MCP servers." >&2
    echo "Leave empty to skip a server." >&2
    echo >&2

    if [ -t 2 ]; then
        if [ -z "$KD_CONTEXT7_TOKEN" ]; then
            echo -n "Context7 API token: " >&2
            read -s -r token1 </dev/tty || true
            echo >&2
        fi

        if [ -z "$KD_AINSTRUCT_TOKEN" ]; then
            echo -n "Ainstruct API token: " >&2
            read -s -r token2 </dev/tty || true
            echo >&2
        fi
    else
        echo "No TTY available. Tokens must be set manually in the volume." >&2
    fi

    if [ -n "$token1" ] || [ -n "$token2" ]; then
        if [ "$ENCRYPTED" -eq 1 ]; then
            echo "Encrypting tokens..." >&2
            encrypt_tokens "$token1" "$token2"
        else
            printf 'KD_CONTEXT7_TOKEN=%s\nKD_AINSTRUCT_TOKEN=%s\n' "$token1" "$token2" | \
                docker run --rm -i --entrypoint "" \
                    -v "${DATA_VOLUME}:${KILO_HOME}" \
                    "$IMAGE" \
                    sh -c "mkdir -p \"\$(dirname '${TOKEN_FILE}')\" && cat > '${TOKEN_FILE}'"
        fi
        KD_CONTEXT7_TOKEN="$token1"
        KD_AINSTRUCT_TOKEN="$token2"
    fi
}

ainstruct_login() {
    local username=""
    local password=""
    local response=""
    local http_code=""
    local access_token=""
    local refresh_token=""
    local expires_in=""
    local user_id=""

    echo "Ainstruct authentication:" >&2

    while true; do
        echo -n "Username: " >&2
        read -r username </dev/tty || { echo "Error: Failed to read username." >&2; exit 1; }

        if [ -n "$username" ]; then
            break
        fi
        echo "Username cannot be empty." >&2
    done

    echo -n "Password: " >&2
    read -s -r password </dev/tty || { echo >&2; echo "Error: Failed to read password." >&2; exit 1; }
    echo >&2

    if [ -z "$password" ]; then
        echo "Error: Password cannot be empty." >&2
        exit 1
    fi

    echo "Logging in..." >&2

    response=$(docker run --rm --entrypoint "" \
        -e "USERNAME=${username}" \
        -e "PASSWORD=${password}" \
        -e "API_URL=${KD_AINSTRUCT_API_URL}" \
        "$IMAGE" \
        sh -c 'curl -s -w "\n%{http_code}" -X POST "${API_URL}/auth/login" \
            -H "Content-Type: application/json" \
            -d "$(jq -n --arg u "$USERNAME" --arg p "$PASSWORD" "{username: \$u, password: \$p}")"
    ' 2>/dev/null)

    http_code=$(echo "$response" | tail -n1)
    response=$(echo "$response" | sed '$d')

    case "$http_code" in
        200)
            access_token=$(echo "$response" | jq -r '.access_token // empty' 2>/dev/null)
            refresh_token=$(echo "$response" | jq -r '.refresh_token // empty' 2>/dev/null)
            expires_in=$(echo "$response" | jq -r '.expires_in // empty' 2>/dev/null)
            if [ -z "$access_token" ]; then
                echo "Error: Login succeeded but no access token in response." >&2
                exit 1
            fi
            if [ -n "$expires_in" ]; then
                echo "Token expires in ${expires_in}s" >&2
            fi
            ;;
        401)
            echo "Error: Invalid credentials." >&2
            echo "Register: https://ainstruct-dev.kralicinora.cz/register" >&2
            echo "Reset password: https://ainstruct-dev.kralicinora.cz/login" >&2
            exit 1
            ;;
        403)
            echo "Error: Account is disabled." >&2
            echo "Register: https://ainstruct-dev.kralicinora.cz/register" >&2
            echo "Reset password: https://ainstruct-dev.kralicinora.cz/login" >&2
            exit 1
            ;;
        0)
            echo "Error: Failed to connect to Ainstruct API. Check your network connection." >&2
            exit 1
            ;;
        *)
            error_message=$(echo "$response" | jq -r '.detail.message // "Unknown error"' 2>/dev/null)
            echo "Error: Login failed with status ${http_code}: ${error_message}" >&2
            echo "Register: https://ainstruct-dev.kralicinora.cz/register" >&2
            echo "Reset password: https://ainstruct-dev.kralicinora.cz/login" >&2
            exit 1
            ;;
    esac

    echo "Login successful. Fetching user profile..." >&2

    response=$(docker run --rm --entrypoint "" \
        -e "ACCESS_TOKEN=${access_token}" \
        -e "API_URL=${KD_AINSTRUCT_API_URL}" \
        "$IMAGE" \
        sh -c 'curl -s -w "\n%{http_code}" -X GET "${API_URL}/auth/profile" \
            -H "Authorization: Bearer ${ACCESS_TOKEN}"
    ' 2>/dev/null)

    http_code=$(echo "$response" | tail -n1)
    response=$(echo "$response" | sed '$d')

    case "$http_code" in
        200)
            user_id=$(echo "$response" | jq -r '.user_id // empty' 2>/dev/null)
            if [ -z "$user_id" ]; then
                echo "Error: Profile fetched but no user_id in response." >&2
                exit 1
            fi
            ;;
        0)
            echo "Error: Failed to connect to Ainstruct API for profile." >&2
            exit 1
            ;;
        *)
            echo "Error: Failed to fetch profile with status ${http_code}." >&2
            exit 1
            ;;
    esac

    VOLUME_PASSWORD="$user_id"
    derive_volume_name

    KD_AINSTRUCT_SYNC_TOKEN="$access_token"
    KD_AINSTRUCT_SYNC_REFRESH_TOKEN="$refresh_token"
    if [ -n "$expires_in" ]; then
        KD_AINSTRUCT_SYNC_TOKEN_EXPIRY="$(($(date +%s) + expires_in))"
    fi

    echo "Authenticated as ${username} (user_id: ${user_id})." >&2
}

# --- Parse flags -------------------------------------------------------------

ONCE=0
ENCRYPTED=0
PLAYWRIGHT_ENABLED=0
DOCKER_ENABLED=0
ZELLIJ_ENABLED=0
NETWORK=""
NETWORK_FLAG=0
KD_AINSTRUCT_ENABLED=0
SSH_ENABLED=0
FILTERED_ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --once)
            ONCE=1
            ;;
        --password|-p)
            ENCRYPTED=1
            ;;
        --ainstruct)
            KD_AINSTRUCT_ENABLED=1
            ENCRYPTED=1
            ;;
        --playwright)
            PLAYWRIGHT_ENABLED=1
            ;;
        --docker)
            DOCKER_ENABLED=1
            ;;
        --zellij)
            ZELLIJ_ENABLED=1
            ;;
        --ssh)
            SSH_ENABLED=1
            ;;
        --network)
            NETWORK_FLAG=1
            if [ $# -ge 2 ] && [[ "$2" != --* ]]; then
                NETWORK="$2"
                shift
            fi
            ;;
        --network=*)
            NETWORK_FLAG=1
            NETWORK="${1#--network=}"
            ;;
        *)
            FILTERED_ARGS+=("$1")
            ;;
    esac
    shift
done

# Resolve image tag
IMAGE="${REPO}:latest"

# Replace positional parameters with filtered args
set -- "${FILTERED_ARGS[@]}"

# --- Docker socket access ----------------------------------------------------

DOCKER_GID=""
if [ "$DOCKER_ENABLED" -eq 1 ]; then
    if [ ! -S /var/run/docker.sock ]; then
        echo "Error: /var/run/docker.sock not found. Is Docker running?" >&2
        exit 1
    fi

    DOCKER_GID=$(stat -c '%g' /var/run/docker.sock)
fi

# --- SSH agent forwarding --------------------------------------------------

SSH_AGENT_FORWARDING=0
SSH_AGENT_STARTED=0
if [ "$SSH_ENABLED" -eq 1 ]; then
    if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "${SSH_AUTH_SOCK}" ]; then
        SSH_AGENT_FORWARDING=1
    else
        # Auto-start ssh-agent if none is running
        _agent_output=$(ssh-agent -s 2>/dev/null) || true
        if [ -n "$_agent_output" ]; then
            eval "$_agent_output"
            export SSH_AUTH_SOCK SSH_AGENT_PID
            SSH_AGENT_STARTED=1
            SSH_AGENT_FORWARDING=1
            # Auto-add all private keys found in ~/.ssh/
            if [ -d "$HOME/.ssh" ]; then
                for _key in "$HOME/.ssh"/*; do
                    [ -f "$_key" ] || continue
                    case "$_key" in *.pub) continue ;; esac
                    head -1 "$_key" 2>/dev/null | grep -q "PRIVATE KEY" || continue
                    ssh-add "$_key" 2>/dev/null || true
                done
            fi
            unset _key _agent_output
        fi
    fi
fi

# --- Docker daemon check ---------------------------------------------------

if ! docker info >/dev/null 2>&1; then
    echo "Error: Docker daemon is not running." >&2
    exit 1
fi

# --- Handle "help" argument ------------------------------------------------

if [ "${1:-}" = "help" ]; then
    cat >&2 <<'EOF'
Usage: kilo-docker [--once] [--password] [--ainstruct] [--playwright] [--docker] [--ssh] [--zellij] [--network <name>] [command] [args...]

Commands:
  (no command)      Start Kilo in interactive mode
  run "prompt"      Run Kilo in autonomous mode with a prompt
  sessions [name]       List sessions or attach to one by name/index
  sessions cleanup [-y] [name]  Remove a session (interactive if no name given)
  networks          List available Docker networks
  backup [-f]       Create backup of volume to tar.gz (auto-names with timestamp)
  restore <file> [-f] [--volume <name>]  Restore volume from backup
  init              Reset configuration (remove volume)
  cleanup           Remove volume, containers, images, and installed script
  install           Install kilo-docker as a global command (~/.local/bin)
  update            Pull the latest Docker image and update the installed script
  update-config     Download latest opencode.json template and merge with existing config
  help              Show this help message (wrapper)

Options:
  --once            Run a one-time session without persisting data (no volume)
  --password, -p    Protect volume with a password (encrypts tokens, derives volume name from password)
  --ainstruct       Encrypt tokens using Ainstruct user_id for volume naming
  --playwright      Start a Playwright MCP sidecar container for browser automation
  --docker          Mount Docker socket for container management from within Kilo
  --ssh             Enable SSH agent forwarding into the container
  --zellij          Start with Zellij multiplexer (detach: Ctrl+P Ctrl+Q, reattach: kilo-docker sessions)
  --network <name>  Connect the container to a Docker network

Security (--password):
  When --password is used, the volume name is derived from the password hash,
  making it non-discoverable by other users. API tokens are encrypted with
  AES-256-CBC before being stored in the volume.

  Without --password, the volume name is kilo-data-<username> and tokens are
  stored in plaintext (original behavior).

Security (--ainstruct):
  Encrypts tokens using AES-256-CBC. Uses Ainstruct user_id for volume naming.

Security (--docker):
  Mounting the Docker socket grants full Docker API access inside the container.
  This is equivalent to root access on the host. Only use this in trusted
  environments.

SSH Agent (--ssh):
  When --ssh is passed, the host SSH agent is mounted into the container,
  so git and ssh use your host keys without copying private keys.
  If no SSH agent is running, one is started automatically and all private
  keys found in ~/.ssh/ are added.
  Ensure your key is loaded: ssh-add -l

Note:
  Use "kilo-docker help" for this wrapper help.
  Use "kilo-docker --help" for Kilo CLI help.

Examples:
  kilo-docker                                    # interactive mode
  kilo-docker run "fix build errors"             # autonomous mode
  kilo-docker --password                         # interactive mode with encryption
  kilo-docker --ainstruct                        # interactive mode with Ainstruct encryption
  kilo-docker --password init                    # reset encrypted volume
  kilo-docker backup                             # create backup with auto-generated name
  kilo-docker backup -f backup.tar.gz            # create backup with custom name
  kilo-docker restore backup.tar.gz              # restore from backup
  kilo-docker --once                             # one-time interactive session
  kilo-docker --once run "prompt"                # one-time autonomous session
  kilo-docker --playwright                       # with Playwright browser automation
  kilo-docker --docker                           # with Docker socket access
  kilo-docker --ssh                              # with SSH agent forwarding
  kilo-docker --zellij                           # start/reattach Zellij container for this workspace
  kilo-docker --network host                     # connect to host network
  kilo-docker sessions                           # list all sessions
  kilo-docker sessions 1                         # attach to session by index
  kilo-docker sessions kilo-abc123def456         # attach to session by name
  kilo-docker sessions cleanup                   # interactively remove a session
  kilo-docker sessions cleanup -y 2              # remove session at index 2 without confirmation
  kilo-docker networks                           # list available Docker networks
  kilo-docker init                               # reset configuration
  kilo-docker cleanup                            # remove volume, containers, images, script
  kilo-docker install                            # install as global command
  kilo-docker update                             # update script and pull latest image
  kilo-docker update-config                      # update config template, preserve customizations
EOF
    exit 0
fi

# --- Handle "networks" argument ----------------------------------------------

if [ "${1:-}" = "networks" ]; then
    docker network ls --format "{{.Name}}"
    exit 0
fi

# --- Handle "sessions" argument -----------------------------------------------

if [ "${1:-}" = "sessions" ]; then
    shift
    ATTACH_TARGET=""
    CLEANUP_MODE=0
    CLEANUP_YES=0

    if [ "${1:-}" = "cleanup" ]; then
        CLEANUP_MODE=1
        shift
        if [ "${1:-}" = "-y" ] || [ "${1:-}" = "--yes" ]; then
            CLEANUP_YES=1
            shift
        fi
    fi

    if [ $# -gt 0 ]; then
        ATTACH_TARGET="$1"
    fi

    # --- Helper: get session list ---
    _get_sessions() {
        docker ps -a --filter "label=kilo.workspace" --format "{{.Names}}\t{{.Status}}\t{{.Labels}}" 2>/dev/null
    }

    # --- Helper: display session table ---
    _show_sessions() {
        local SESSIONS="$1"
        printf "%-4s %-22s %-32s %-52s %s\n" "#" "NAME" "STATUS" "WORKSPACE" "ARGS" >&2
        printf "%-4s %-22s %-32s %-52s %s\n" "---" "----------------------" "--------------------------------" "----------------------------------------------------" "-----" >&2
        local INDEX=1
        while IFS=$'\t' read -r name status labels; do
            workspace=$(echo "$labels" | tr ',' '\n' | grep '^kilo.workspace=' | cut -d= -f2-)
            args=$(echo "$labels" | tr ',' '\n' | grep '^kilo.args=' | cut -d= -f2-)
            printf "%-4s %-22s %-32s %-52s %s\n" "$INDEX" "$name" "$status" "${workspace:-}" "${args:-}" >&2
            INDEX=$((INDEX + 1))
        done <<< "$SESSIONS"
    }

    # --- Helper: resolve target by name or index ---
    _resolve_target() {
        local target="$1"
        local result=""
        if [[ "$target" =~ ^[0-9]+$ ]]; then
            local SESSIONS
            SESSIONS=$(_get_sessions)
            result=$(echo "$SESSIONS" | sed -n "${target}p" | cut -f1)
            if [ -z "$result" ]; then
                echo "Error: No session at index ${target}." >&2
                return 1
            fi
        else
            if docker inspect "$target" >/dev/null 2>&1; then
                result="$target"
            else
                echo "Error: Container '${target}' not found." >&2
                return 1
            fi
        fi
        echo "$result"
    }

    # --- Cleanup mode ---
    if [ "$CLEANUP_MODE" -eq 1 ]; then
        SESSIONS=$(_get_sessions)
        CONTAINER_TO_CLEAN=""

        if [ -n "$ATTACH_TARGET" ]; then
            CONTAINER_TO_CLEAN=$(_resolve_target "$ATTACH_TARGET") || exit 1
        else
            if [ -z "$SESSIONS" ]; then
                echo "No sessions to clean up." >&2
                exit 0
            fi
            _show_sessions "$SESSIONS"
            echo -n "Select session to remove (number or name): " >&2
            local_selection=""
            read -r local_selection </dev/tty || { echo "Error: Failed to read input." >&2; exit 1; }
            if [ -z "$local_selection" ]; then
                echo "Aborted." >&2
                exit 0
            fi
            CONTAINER_TO_CLEAN=$(_resolve_target "$local_selection") || exit 1
        fi

        if [ "$CLEANUP_YES" -eq 1 ] || confirm "Remove session '${CONTAINER_TO_CLEAN}'? [y/N]: "; then
            docker rm -f "$CONTAINER_TO_CLEAN" >/dev/null 2>&1
            echo "Session '${CONTAINER_TO_CLEAN}' removed." >&2
        else
            echo "Aborted." >&2
        fi
        exit 0
    fi

    # --- List mode: show all kilo sessions ---
    if [ -z "$ATTACH_TARGET" ]; then
        SESSIONS=$(_get_sessions)

        if [ -z "$SESSIONS" ]; then
            echo "No active sessions." >&2
            exit 0
        fi

        _show_sessions "$SESSIONS"
        exit 0
    fi

    # --- Attach mode: resolve target by name or index ---
    CONTAINER_TO_ATTACH=""
    CONTAINER_TO_ATTACH=$(_resolve_target "$ATTACH_TARGET") || exit 1

    CONTAINER_STATUS=$(docker inspect -f '{{.State.Status}}' "$CONTAINER_TO_ATTACH" 2>/dev/null)
    case "$CONTAINER_STATUS" in
        running)
            echo "Attaching to running session '${CONTAINER_TO_ATTACH}' (detach: Ctrl+P Ctrl+Q)..." >&2
            docker attach "$CONTAINER_TO_ATTACH" || true
            reset_terminal
            exit 0
            ;;
        exited|created)
            echo "Starting session '${CONTAINER_TO_ATTACH}'..." >&2
            docker start -ai "$CONTAINER_TO_ATTACH" || true
            reset_terminal
            exit 0
            ;;
        *)
            echo "Error: Container '${CONTAINER_TO_ATTACH}' is in state '${CONTAINER_STATUS}'." >&2
            exit 1
            ;;
    esac
fi

# --- Handle "update" argument ----------------------------------------------

if [ "${1:-}" = "update" ]; then
    if [ -f "$INSTALL_TARGET" ]; then
        echo "Updating kilo-docker script..." >&2
        TEMP_FILE="$(mktemp)"
        if curl -fsSL "$GITHUB_RAW" -o "$TEMP_FILE" 2>/dev/null; then
            chmod +x "$TEMP_FILE"
            mv "$TEMP_FILE" "$INSTALL_TARGET"
            echo "Script updated: ${INSTALL_TARGET}" >&2
        else
            rm -f "$TEMP_FILE" 2>/dev/null || true
            echo "Warning: Failed to download script update. Continuing with image pull." >&2
        fi
    else
        echo "kilo-docker script is not installed locally (no file at ${INSTALL_TARGET})." >&2
        echo "Run 'kilo-docker install' to install it first." >&2
    fi

    echo "" >&2
    echo "Pulling Docker image..." >&2
    docker pull "$IMAGE" >&2
    echo "" >&2
    echo "Update complete." >&2
    exit 0
fi

# --- Volume name and password -----------------------------------------------

VOLUME_PASSWORD=""

if [ "$ONCE" -eq 1 ]; then
    # --once: no volume, no password
    DATA_VOLUME=""
elif [ "$KD_AINSTRUCT_ENABLED" -eq 1 ]; then
    # --ainstruct: authenticate with Ainstruct API (always, for fresh JWT tokens)
    if [ -t 2 ] && [ -t 0 ]; then
        ainstruct_login
    else
        echo "Error: --ainstruct requires a TTY." >&2
        exit 1
    fi
    # Volume is derived from user_id; check if it already exists
    if docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        # Existing volume: load MCP tokens (sync tokens are runtime-only from login)
        if [ "$ENCRYPTED" -eq 1 ]; then
            DECRYPTED=$(decrypt_tokens) || true
            if [ -n "$DECRYPTED" ]; then
                KD_CONTEXT7_TOKEN=$(echo "$DECRYPTED" | grep '^KD_CONTEXT7_TOKEN=' | cut -d= -f2- || true)
                KD_AINSTRUCT_TOKEN=$(echo "$DECRYPTED" | grep '^KD_AINSTRUCT_TOKEN=' | cut -d= -f2- || true)
            fi
        fi
    fi
elif [ "$ENCRYPTED" -eq 1 ]; then
    # --password: derive volume name from password
    if [ -t 2 ] && [ -t 0 ]; then
        prompt_password skip_confirm
        derive_volume_name
        # If volume doesn't exist yet, confirm the password to avoid typos
        if ! docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
            confirm_password
        fi
    else
        echo "Error: --password requires a TTY. Use --once for ephemeral runs." >&2
        exit 1
    fi
else
    # Default: plaintext volume with username
    DATA_VOLUME="kilo-data-$(whoami)"
fi

# --- Handle "update-config" argument ----------------------------------------

if [ "${1:-}" = "update-config" ]; then
    if [ -z "$DATA_VOLUME" ]; then
        echo "Nothing to update in --once mode." >&2
        exit 0
    fi
    if ! docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        echo "No existing volume found. Run kilo-docker first to create one." >&2
        exit 1
    fi
    echo "Updating opencode.json from repository template..." >&2
    docker run --rm --entrypoint "" \
        -v "${DATA_VOLUME}:${KILO_HOME}" \
        "$IMAGE" \
        sh -c '
            set -e
            TEMPLATE=$(mktemp)
            CONFIG="${HOME}/.config/kilo/opencode.json"
            if curl -fsSL "https://raw.githubusercontent.com/mbabic84/kilo-docker/main/configs/opencode.json" -o "$TEMPLATE"; then
                if [ -f "$CONFIG" ]; then
                    jq -s ".[0] * .[1]" "$TEMPLATE" "$CONFIG" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "$CONFIG"
                    echo "Config merged. Existing customizations preserved, new servers added."
                else
                    cp "$TEMPLATE" "$CONFIG"
                    echo "Config created from template."
                fi
            else
                echo "Error: Failed to download config template."
                exit 1
            fi
        '
    exit 0
fi

# --- Handle "init" argument ------------------------------------------------

if [ "${1:-}" = "init" ]; then
    if [ -z "$DATA_VOLUME" ]; then
        echo "Nothing to reset in --once mode." >&2
        exit 0
    fi
    if docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        if confirm "Remove volume '${DATA_VOLUME}' and reset all configuration? [y/N]: "; then
            docker volume rm "$DATA_VOLUME" >/dev/null
            echo "Volume removed. You will be prompted for tokens on next run." >&2
        fi
    else
        if [ "$ENCRYPTED" -eq 1 ]; then
            echo "No existing volume found for this password." >&2
        else
            echo "No existing volume found." >&2
        fi
    fi
    exit 0
fi

# --- Handle "cleanup" argument ----------------------------------------------

if [ "${1:-}" = "cleanup" ]; then
    if ! confirm "Remove volume, containers, and images for kilo-docker? [y/N]: "; then
        echo "Aborted." >&2
        exit 0
    fi

    CONTAINERS=$(docker ps -a --filter "ancestor=${REPO}" -q 2>/dev/null || true)
    if [ -n "$CONTAINERS" ]; then
        echo "Removing containers..." >&2
        echo "$CONTAINERS" | xargs docker rm -f >/dev/null 2>&1 || true
    fi

    if [ -n "$DATA_VOLUME" ] && docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        echo "Removing volume '${DATA_VOLUME}'..." >&2
        docker volume rm "$DATA_VOLUME" >/dev/null
    fi

    local_img="${REPO}:latest"
    if docker image inspect "$local_img" >/dev/null 2>&1; then
        echo "Removing image '${local_img}'..." >&2
        docker rmi "$local_img" >/dev/null
    fi

    if [ -L "$INSTALL_TARGET" ] || [ -f "$INSTALL_TARGET" ]; then
        echo "Removing installed script '${INSTALL_TARGET}'..." >&2
        rm -f "$INSTALL_TARGET"
    fi
    if [ -d "$INSTALL_DIR" ]; then
        rmdir "$INSTALL_DIR" 2>/dev/null || true
    fi

    echo "Cleanup complete." >&2
    exit 0
fi

# --- Handle "backup" argument ----------------------------------------------

if [ "${1:-}" = "backup" ]; then
    shift
    BACKUP_FILE=""
    FORCE_BACKUP=0

    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--force)
                FORCE_BACKUP=1
                ;;
            -*)
                echo "Unknown option: $1" >&2
                exit 1
                ;;
            *)
                BACKUP_FILE="$1"
                ;;
        esac
        shift
    done

    if [ -z "$DATA_VOLUME" ]; then
        echo "Error: backup is not available in --once mode." >&2
        exit 1
    fi

    if ! docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        echo "Error: volume '${DATA_VOLUME}' does not exist." >&2
        exit 1
    fi

    if [ -z "$BACKUP_FILE" ]; then
        TIMESTAMP=$(date +%Y%m%d-%H%M%S)
        if [ "$ENCRYPTED" -eq 1 ]; then
            BACKUP_FILE="kilo-backup-${TIMESTAMP}.tar.gz.enc"
        else
            BACKUP_FILE="kilo-backup-${TIMESTAMP}.tar.gz"
        fi
    fi

    if [ -f "$BACKUP_FILE" ] && [ "$FORCE_BACKUP" -eq 0 ]; then
        if ! confirm "Backup file '${BACKUP_FILE}' exists. Overwrite? [y/N]: "; then
            echo "Aborted." >&2
            exit 0
        fi
    fi

    echo "Creating backup of volume '${DATA_VOLUME}' to '${BACKUP_FILE}'..." >&2

    TEMP_DIR=$(mktemp -d)
    TEMP_CONTAINER="kilo-backup-temp-$$"
    docker run --rm -d --name "$TEMP_CONTAINER" -v "${DATA_VOLUME}:/src:ro" alpine:latest tail -f /dev/null >/dev/null 2>&1
    sleep 0.5
    docker cp "$TEMP_CONTAINER:/src/." "$TEMP_DIR/src" 2>/dev/null
    docker rm -f "$TEMP_CONTAINER" >/dev/null 2>&1
    tar czf "${BACKUP_FILE}" -C "$TEMP_DIR/src" .
    rm -rf "$TEMP_DIR"

    if [ "$ENCRYPTED" -eq 1 ]; then
        echo "Backup created (encrypted): ${BACKUP_FILE}" >&2
    else
        echo "Backup created: ${BACKUP_FILE}" >&2
    fi
    exit 0
fi

# --- Handle "restore" argument ----------------------------------------------

if [ "${1:-}" = "restore" ]; then
    shift
    BACKUP_FILE=""
    FORCE_RESTORE=0
    TARGET_VOLUME=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--force)
                FORCE_RESTORE=1
                ;;
            -v|--volume)
                shift
                TARGET_VOLUME="$1"
                ;;
            -*)
                echo "Unknown option: $1" >&2
                exit 1
                ;;
            *)
                BACKUP_FILE="$1"
                ;;
        esac
        shift
    done

    if [ -z "$TARGET_VOLUME" ]; then
        if [ -z "$DATA_VOLUME" ]; then
            echo "Error: no volume specified. Use --once mode or provide --volume." >&2
            exit 1
        fi
        TARGET_VOLUME="$DATA_VOLUME"
    fi

    if [ -z "$BACKUP_FILE" ]; then
        echo "Error: backup file path required." >&2
        echo "Usage: kilo-docker restore <backup-file> [-f] [--volume <name>]" >&2
        exit 1
    fi

    if [ ! -f "$BACKUP_FILE" ]; then
        echo "Error: backup file '${BACKUP_FILE}' not found." >&2
        exit 1
    fi

    if ! tar -tzf "$BACKUP_FILE" >/dev/null 2>&1; then
        echo "Error: invalid or corrupted backup file." >&2
        exit 1
    fi

    if docker volume inspect "$TARGET_VOLUME" >/dev/null 2>&1; then
        if [ "$FORCE_RESTORE" -eq 0 ]; then
            if ! confirm "Volume '${TARGET_VOLUME}' exists and will be overwritten. Continue? [y/N]: "; then
                echo "Aborted." >&2
                exit 0
            fi
        fi
        docker volume rm "$TARGET_VOLUME" >/dev/null 2>&1 || true
    fi

    echo "Restoring backup '${BACKUP_FILE}' to volume '${TARGET_VOLUME}'..." >&2

    docker volume create "$TARGET_VOLUME" >/dev/null

    if ! tar -xzf "$BACKUP_FILE" -C "$(docker run --rm -v "${TARGET_VOLUME}:/dest" alpine echo /dest)" 2>/dev/null; then
        docker run --rm -v "${TARGET_VOLUME}:/dest" -v "$(dirname "$BACKUP_FILE"):/backup:ro" alpine \
            tar xzf /backup/"$(basename "$BACKUP_FILE")" -C /dest
    fi

    docker run --rm -v "${TARGET_VOLUME}:/dest" alpine chown -R 1000:1000 /dest 2>/dev/null || true

    echo "Restore complete." >&2
    exit 0
fi

# --- Handle "install" argument -----------------------------------------------

if [ "${1:-}" = "install" ]; then
    SOURCE_SCRIPT=""

    if [ -f "$0" ]; then
        SOURCE_SCRIPT="$(realpath "$0")"
    fi

    DOWNLOADED_SCRIPT=""

    if [ -z "$SOURCE_SCRIPT" ] || [ ! -f "$SOURCE_SCRIPT" ]; then
        echo "Source script path not available (e.g., running via pipe). Downloading..." >&2
        DOWNLOADED_SCRIPT="$(mktemp)"
        if curl -fsSL "$GITHUB_RAW" -o "$DOWNLOADED_SCRIPT" 2>/dev/null; then
            chmod +x "$DOWNLOADED_SCRIPT"
            SOURCE_SCRIPT="$DOWNLOADED_SCRIPT"
        else
            echo "Error: Failed to download script from ${GITHUB_RAW}." >&2
            exit 1
        fi
    fi

    mkdir -p "$INSTALL_DIR"

    if [ -n "$DOWNLOADED_SCRIPT" ]; then
        cp "$SOURCE_SCRIPT" "$INSTALL_TARGET"
        rm -f "$DOWNLOADED_SCRIPT"
    elif [ -L "$INSTALL_TARGET" ]; then
        echo "kilo-docker is already installed at ${INSTALL_TARGET}" >&2
        echo "Updating symlink..." >&2
        ln -sf "$SOURCE_SCRIPT" "$INSTALL_TARGET"
    elif [ -f "$INSTALL_TARGET" ]; then
        echo "kilo-docker already exists at ${INSTALL_TARGET} (not a symlink)." >&2
        if confirm "Replace it? [y/N]: "; then
            ln -sf "$SOURCE_SCRIPT" "$INSTALL_TARGET"
        else
            echo "Aborted." >&2
            exit 0
        fi
    else
        ln -s "$SOURCE_SCRIPT" "$INSTALL_TARGET" 2>/dev/null || {
            echo "Symlink failed (cross-device?). Copying instead..." >&2
            cp "$SOURCE_SCRIPT" "$INSTALL_TARGET"
        }
    fi

    chmod +x "$INSTALL_TARGET"

    case ":${PATH}:" in
        *":${INSTALL_DIR}:"*)
            ;;
        *)
            echo "" >&2
            echo "Warning: ${INSTALL_DIR} is not on your PATH." >&2
            if [ -f "$HOME/.profile" ] && grep -q '.local/bin' "$HOME/.profile"; then
                echo "Your ~/.profile already configures ~/.local/bin for PATH, but it was not active at login." >&2
                echo "Run one of the following to activate it:" >&2
                echo '  source ~/.profile' >&2
                echo "Or log out and log back in." >&2
            else
                echo "Add the following line to your ~/.bashrc (or ~/.zshrc):" >&2
                echo "  export PATH=\"\$HOME/.local/bin:\$PATH\"" >&2
                echo "Then restart your shell or run: source ~/.bashrc" >&2
            fi
            ;;
    esac

    echo "" >&2
    echo "Pulling Docker image..." >&2
    docker pull "$IMAGE" >&2
    echo "" >&2
    echo "Installed successfully: ${INSTALL_TARGET} -> ${SOURCE_SCRIPT}" >&2
    echo "Run 'kilo-docker' from any directory." >&2
    exit 0
fi

# --- Interactive network selection -------------------------------------------

if [ "$NETWORK_FLAG" -eq 1 ] && [ -z "$NETWORK" ] && [ -t 0 ] && [ -t 2 ]; then
    if mapfile -t AVAILABLE_NETWORKS < <(docker network ls --format "{{.Name}}" 2>/dev/null) && [ ${#AVAILABLE_NETWORKS[@]} -gt 0 ]; then
        echo "Available Docker networks:" >&2
        for i in "${!AVAILABLE_NETWORKS[@]}"; do
            echo "  $((i + 1)). ${AVAILABLE_NETWORKS[$i]}" >&2
        done
        echo -n "Select a network (number) or press Enter to use default: " >&2
        local_selection=""
        read -r local_selection </dev/tty || local_selection=""
        if [ -n "$local_selection" ]; then
            if [[ "$local_selection" =~ ^[0-9]+$ ]] && [ "$local_selection" -ge 1 ] && [ "$local_selection" -le ${#AVAILABLE_NETWORKS[@]} ]; then
                NETWORK="${AVAILABLE_NETWORKS[$((local_selection - 1))]}"
                echo "Using network: ${NETWORK}" >&2
            else
                echo "Invalid selection. Using default network." >&2
            fi
        fi
    fi
fi

# --- Read/load tokens -------------------------------------------------------

KD_CONTEXT7_TOKEN=""
KD_AINSTRUCT_TOKEN=""
if [ "$KD_AINSTRUCT_ENABLED" -eq 0 ]; then
    KD_AINSTRUCT_SYNC_TOKEN=""
    KD_AINSTRUCT_SYNC_REFRESH_TOKEN=""
    KD_AINSTRUCT_SYNC_TOKEN_EXPIRY=""
fi

if [ "$ONCE" -eq 0 ] && [ "$KD_AINSTRUCT_ENABLED" -eq 0 ]; then
    if docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        if [ "$ENCRYPTED" -eq 1 ]; then
            # Encrypted mode: decrypt existing tokens
            DECRYPTED=$(decrypt_tokens) || true

            if [ -n "$DECRYPTED" ]; then
                KD_CONTEXT7_TOKEN=$(echo "$DECRYPTED" | grep '^KD_CONTEXT7_TOKEN=' | cut -d= -f2- || true)
                KD_AINSTRUCT_TOKEN=$(echo "$DECRYPTED" | grep '^KD_AINSTRUCT_TOKEN=' | cut -d= -f2- || true)
            fi
        else
            # Plaintext mode: read tokens directly
            EXISTING=$(docker run --rm --entrypoint "" \
                -v "${DATA_VOLUME}:${KILO_HOME}" \
                "$IMAGE" \
                cat "$TOKEN_FILE" 2>/dev/null || true)

            if [ -n "$EXISTING" ]; then
                KD_CONTEXT7_TOKEN=$(echo "$EXISTING" | grep '^KD_CONTEXT7_TOKEN=' | cut -d= -f2- || true)
                KD_AINSTRUCT_TOKEN=$(echo "$EXISTING" | grep '^KD_AINSTRUCT_TOKEN=' | cut -d= -f2- || true)
            fi
        fi
    fi

    # If still no tokens, prompt for new ones
    if [ -z "$KD_CONTEXT7_TOKEN" ] && [ -z "$KD_AINSTRUCT_TOKEN" ]; then
        prompt_missing_tokens
    fi
fi

# --- Playwright sidecar ----------------------------------------------------

PLAYWRIGHT_IMAGE="mcr.microsoft.com/playwright/mcp"
PLAYWRIGHT_NETWORK=""
PLAYWRIGHT_CONTAINER="playwright-mcp"

if [ "$PLAYWRIGHT_ENABLED" -eq 1 ]; then
    if [ -n "$NETWORK" ]; then
        echo "Error: --playwright and --network are mutually exclusive." >&2
        echo "       Playwright creates its own network." >&2
        exit 1
    fi

    PLAYWRIGHT_NETWORK="kilo-playwright-$(whoami)"

    # Create network (idempotent)
    if ! docker network inspect "$PLAYWRIGHT_NETWORK" >/dev/null 2>&1; then
        docker network create "$PLAYWRIGHT_NETWORK" >/dev/null
    fi

    # Pull Playwright MCP image
    echo "Pulling Playwright MCP image..." >&2
    docker pull "$PLAYWRIGHT_IMAGE" >/dev/null 2>&1

    # Ensure output directory exists
    mkdir -p "$(pwd)/.playwright-mcp"

    # Remove any stale container
    docker rm -f "$PLAYWRIGHT_CONTAINER" >/dev/null 2>&1 || true

    # Start Playwright MCP in HTTP mode.
    # Uses --entrypoint node (overrides default entrypoint) with cli.js
    # relative to image WORKDIR /app.
    docker run -d --rm --init \
        --name "$PLAYWRIGHT_CONTAINER" \
        --network "$PLAYWRIGHT_NETWORK" \
        --entrypoint node \
        -v "$(pwd):/mnt/$(basename "$(pwd)")" \
        "$PLAYWRIGHT_IMAGE" \
        cli.js --headless --browser chromium --no-sandbox --port 8931 --host 0.0.0.0 --output-dir "/mnt/$(basename "$(pwd)")/.playwright-mcp" --allowed-hosts '*' \
        >/dev/null

    # Wait for Playwright MCP to be ready
    echo -n "Waiting for Playwright MCP..." >&2
    for i in $(seq 1 30); do
        # Check container is still running
        if [ "$(docker inspect -f '{{.State.Status}}' "$PLAYWRIGHT_CONTAINER" 2>/dev/null)" != "running" ]; then
            echo " container stopped." >&2
            echo "Error: Playwright MCP container exited unexpectedly." >&2
            docker logs "$PLAYWRIGHT_CONTAINER" 2>&1 | tail -5 >&2
            docker rm -f "$PLAYWRIGHT_CONTAINER" >/dev/null 2>&1 || true
            docker network rm "$PLAYWRIGHT_NETWORK" >/dev/null 2>&1 || true
            exit 1
        fi
        # Check if port 8931 is listening (MCP endpoint rejects plain GET, so use TCP check)
        if docker exec "$PLAYWRIGHT_CONTAINER" node -e "
            const net = require('net');
            const s = net.connect(8931, '127.0.0.1', () => { s.destroy(); process.exit(0); });
            s.on('error', () => process.exit(1));
            s.setTimeout(2000, () => { s.destroy(); process.exit(1); });
        " 2>/dev/null; then
            echo " ready." >&2
            break
        fi
        if [ "$i" -eq 30 ]; then
            echo " timeout." >&2
            echo "Error: Playwright MCP did not become ready in 30s." >&2
            docker logs "$PLAYWRIGHT_CONTAINER" 2>&1 | tail -5 >&2
            docker rm -f "$PLAYWRIGHT_CONTAINER" >/dev/null 2>&1 || true
            docker network rm "$PLAYWRIGHT_NETWORK" >/dev/null 2>&1 || true
            exit 1
        fi
        sleep 1
        echo -n "." >&2
    done

    # Cleanup function called on EXIT (fires after exec'd docker run exits)
    cleanup_playwright() {
        docker rm -f "$PLAYWRIGHT_CONTAINER" >/dev/null 2>&1 || true
        docker network rm "$PLAYWRIGHT_NETWORK" >/dev/null 2>&1 || true
    }
    trap cleanup_playwright EXIT

    # Use the Playwright network for the Kilo container
    NETWORK="$PLAYWRIGHT_NETWORK"
fi

# --- Container name ---------------------------------------------------------

WORKSPACE_HASH="$(printf '%s' "$(pwd)" | sha256sum | cut -c1-12)"
CONTAINER_NAME="kilo-${WORKSPACE_HASH}"

# Clean up any existing container with the same name
CONTAINER_STATE=$(docker inspect -f '{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null || echo "not_found")
if [ "$ONCE" -eq 1 ]; then
    # --once: force remove any existing container (including running)
    if [ "$CONTAINER_STATE" != "not_found" ]; then
        docker rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true
    fi
    CONTAINER_STATE="not_found"
else
    case "$CONTAINER_STATE" in
        exited|dead|created)
            docker rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true
            CONTAINER_STATE="not_found"
            ;;
    esac
fi

# --- Workspace path conflict check ----------------------------------------

CURRENT_PWD="$(pwd)"
if [ -z "$ONCE" ] || [ "$ONCE" -eq 0 ]; then
    case "$CURRENT_PWD" in
        "/home/kilo-t8x3m7kp"|"/home/kilo-t8x3m7kp"/*)
            echo "Warning: Current directory (${CURRENT_PWD}) overlaps with the container's home path." >&2
            echo "This may cause permission issues or unexpected behavior." >&2
            ;;
    esac
fi

# --- Build docker run args -------------------------------------------------

DOCKER_ARGS=(
    --init
    --ipc=host
    -e "PUID=$(id -u)"
    -e "PGID=$(id -g)"
    -v "${CURRENT_PWD}:${CURRENT_PWD}"
    -w "${CURRENT_PWD}"
)

if [ "$ONCE" -eq 0 ] && [ -n "$DATA_VOLUME" ]; then
    DOCKER_ARGS+=(-v "${DATA_VOLUME}:${KILO_HOME}")
fi

if [ "$ONCE" -eq 1 ]; then
    DOCKER_ARGS+=(--rm)
fi

DOCKER_ARGS+=(--label "kilo.workspace=${CURRENT_PWD}")

# Build kilo.args label from active flags and positional args
KD_SESSION_ARGS=""
[ "$ONCE" -eq 1 ] && KD_SESSION_ARGS+="--once "
[ "$ZELLIJ_ENABLED" -eq 1 ] && KD_SESSION_ARGS+="--zellij "
[ "$PLAYWRIGHT_ENABLED" -eq 1 ] && KD_SESSION_ARGS+="--playwright "
[ "$DOCKER_ENABLED" -eq 1 ] && KD_SESSION_ARGS+="--docker "
[ "$SSH_AGENT_FORWARDING" -eq 1 ] && KD_SESSION_ARGS+="ssh-agent "
[ "$ENCRYPTED" -eq 1 ] && [ "$KD_AINSTRUCT_ENABLED" -eq 0 ] && KD_SESSION_ARGS+="-p "
[ "$KD_AINSTRUCT_ENABLED" -eq 1 ] && KD_SESSION_ARGS+="--ainstruct "
[ -n "$NETWORK" ] && KD_SESSION_ARGS+="--network ${NETWORK} "
[ $# -gt 0 ] && KD_SESSION_ARGS+="$* "
DOCKER_ARGS+=(--label "kilo.args=${KD_SESSION_ARGS% }")

if [ -n "$KD_CONTEXT7_TOKEN" ]; then
    DOCKER_ARGS+=(-e "KD_CONTEXT7_TOKEN=${KD_CONTEXT7_TOKEN}")
fi

if [ -n "$KD_AINSTRUCT_TOKEN" ]; then
    DOCKER_ARGS+=(-e "KD_AINSTRUCT_TOKEN=${KD_AINSTRUCT_TOKEN}")
fi

if [ "$PLAYWRIGHT_ENABLED" -eq 1 ]; then
    DOCKER_ARGS+=(-e "PLAYWRIGHT_ENABLED=1")
fi

if [ "$DOCKER_ENABLED" -eq 1 ]; then
    DOCKER_ARGS+=(-v /var/run/docker.sock:/var/run/docker.sock)
    DOCKER_ARGS+=(-e "DOCKER_ENABLED=1")
    DOCKER_ARGS+=(-e "DOCKER_GID=${DOCKER_GID}")
fi

if [ "$ZELLIJ_ENABLED" -eq 1 ]; then
    DOCKER_ARGS+=(-e "ZELLIJ_ENABLED=1")
fi

if [ "$SSH_AGENT_FORWARDING" -eq 1 ]; then
    DOCKER_ARGS+=(-v "${SSH_AUTH_SOCK}:/ssh-agent.sock")
    DOCKER_ARGS+=(-e "SSH_AUTH_SOCK=/ssh-agent.sock")
fi

DOCKER_ARGS+=(--name "$CONTAINER_NAME")

if [ "$KD_AINSTRUCT_ENABLED" -eq 1 ]; then
    DOCKER_ARGS+=(-e "KD_AINSTRUCT_ENABLED=1")
    DOCKER_ARGS+=(-e "KD_AINSTRUCT_API_URL=${KD_AINSTRUCT_API_URL}")
    if [ -n "$KD_AINSTRUCT_SYNC_TOKEN" ]; then
        DOCKER_ARGS+=(-e "KD_AINSTRUCT_SYNC_TOKEN=${KD_AINSTRUCT_SYNC_TOKEN}")
    fi
    if [ -n "$KD_AINSTRUCT_SYNC_REFRESH_TOKEN" ]; then
        DOCKER_ARGS+=(-e "KD_AINSTRUCT_SYNC_REFRESH_TOKEN=${KD_AINSTRUCT_SYNC_REFRESH_TOKEN}")
    fi
    if [ -n "$KD_AINSTRUCT_SYNC_TOKEN_EXPIRY" ]; then
        DOCKER_ARGS+=(-e "KD_AINSTRUCT_SYNC_TOKEN_EXPIRY=${KD_AINSTRUCT_SYNC_TOKEN_EXPIRY}")
    fi
fi

if [ -n "$NETWORK" ]; then
    DOCKER_ARGS+=(--network "$NETWORK")
fi

# Pass terminal capability variables
for var in TERM COLORTERM LANG LC_ALL; do
    if [ -n "${!var:-}" ]; then
        DOCKER_ARGS+=(-e "${var}=${!var}")
    fi
done

# Pass host timezone
if [ -n "${TZ:-}" ]; then
    DOCKER_ARGS+=(-e "TZ=${TZ}")
elif [ -f /etc/timezone ]; then
    DOCKER_ARGS+=(-e "TZ=$(cat /etc/timezone)")
elif [ -L /etc/localtime ]; then
    DOCKER_ARGS+=(-e "TZ=$(readlink /etc/localtime | sed 's|.*zoneinfo/||')")
fi

# --- Clear sensitive data from shell ----------------------------------------

unset VOLUME_PASSWORD 2>/dev/null || true

# --- Cleanup: kill auto-started ssh-agent on exit --------------------------

if [ "$SSH_AGENT_STARTED" -eq 1 ]; then
    _cleanup_ssh_agent() {
        kill "$SSH_AGENT_PID" 2>/dev/null || true
    }
    trap _cleanup_ssh_agent EXIT
fi

# --- Run --------------------------------------------------------------------

if [ "$CONTAINER_STATE" = "running" ]; then
    docker attach "$CONTAINER_NAME" || true
    reset_terminal
    exit 0
elif [ "$CONTAINER_STATE" = "exited" ] || [ "$CONTAINER_STATE" = "created" ]; then
    docker start -ai "$CONTAINER_NAME" || true
    reset_terminal
    exit 0
    else
        if [ $# -gt 0 ]; then
            if [ -t 0 ]; then
                docker run -it "${DOCKER_ARGS[@]}" "$IMAGE" "$@"
            else
                docker run "${DOCKER_ARGS[@]}" "$IMAGE" "$@"
            fi
        else
            if [ -t 0 ]; then
                docker run -it "${DOCKER_ARGS[@]}" "$IMAGE"
            else
                docker run -i "${DOCKER_ARGS[@]}" "$IMAGE"
            fi
        fi
    fi
