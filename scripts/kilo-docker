#!/usr/bin/env bash
# kilo-docker — Wrapper script for running Kilo in a Docker container.
#
# Usage: kilo-docker [--once] [command] [args...]
# See:   kilo-docker help
#
set -euo pipefail
IFS=$'\n\t'

export PATH="/usr/local/bin:/usr/bin:/bin:${PATH:-}"

readonly IMAGE="ghcr.io/mbabic84/kilo-docker:latest"
readonly DATA_MOUNT="/home/user/.local/share/kilo"
readonly DATA_VOLUME="kilo-data-$(whoami)"
readonly TOKEN_FILE="${DATA_MOUNT}/.tokens.env"
readonly HOST_UID="$(id -u)"
readonly HOST_GID="$(id -g)"

# --- Helper functions --------------------------------------------------------

confirm() {
    local prompt="$1"
    local response=""
    echo -n "$prompt" >&2
    if [ -t 1 ]; then
        read -r response </dev/tty
    else
        response="n"
        echo "n (no TTY)" >&2
    fi
    [[ "${response,,}" == "y" ]]
}

# --- Parse --once flag ------------------------------------------------------

ONCE=0
FILTERED_ARGS=()
for arg in "$@"; do
    if [ "$arg" = "--once" ]; then
        ONCE=1
    else
        FILTERED_ARGS+=("$arg")
    fi
done
# Replace positional parameters with filtered args
set -- "${FILTERED_ARGS[@]}"

# --- Docker daemon check ---------------------------------------------------

if ! docker info >/dev/null 2>&1; then
    echo "Error: Docker daemon is not running." >&2
    exit 1
fi

# --- Handle "init" argument ------------------------------------------------

if [ "${1:-}" = "init" ]; then
    if docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        if confirm "Remove volume '${DATA_VOLUME}' and reset all configuration? [y/N]: "; then
            docker volume rm "$DATA_VOLUME" >/dev/null
            echo "Volume removed. You will be prompted for tokens on next run." >&2
        fi
    else
        echo "No existing volume found." >&2
    fi
    exit 0
fi

# --- Handle "update" argument ----------------------------------------------

if [ "${1:-}" = "update" ]; then
    docker pull "$IMAGE"
    exit 0
fi

# --- Handle "cleanup" argument ----------------------------------------------

if [ "${1:-}" = "cleanup" ]; then
    if ! confirm "Remove volume, containers, and image for kilo-docker? [y/N]: "; then
        echo "Aborted." >&2
        exit 0
    fi

    # Remove all containers referencing the image (including running)
    CONTAINERS=$(docker ps -a --filter "ancestor=${IMAGE}" -q 2>/dev/null || true)
    if [ -n "$CONTAINERS" ]; then
        echo "Removing containers..." >&2
        echo "$CONTAINERS" | xargs docker rm -f >/dev/null 2>&1 || true
    fi

    # Remove the named volume
    if docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        echo "Removing volume '${DATA_VOLUME}'..." >&2
        docker volume rm "$DATA_VOLUME" >/dev/null
    fi

    # Remove the image
    if docker image inspect "$IMAGE" >/dev/null 2>&1; then
        echo "Removing image '${IMAGE}'..." >&2
        docker rmi "$IMAGE" >/dev/null
    fi

    echo "Cleanup complete." >&2
    exit 0
fi

# --- Handle "help" argument ------------------------------------------------

if [ "${1:-}" = "help" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    cat >&2 <<'EOF'
Usage: kilo-docker [--once] [command] [args...]

Commands:
  (no command)      Start Kilo in interactive mode
  run "prompt"      Run Kilo in autonomous mode with a prompt
  init              Reset configuration (remove volume, re-enter tokens)
  cleanup           Remove volume, containers, and image
  update            Pull the latest Docker image
  help              Show this help message

Options:
  --once            Run a one-time session without persisting data (no volume)

Environment variables:
  CONTEXT7_TOKEN    API token for Context7 MCP server
  AINSTRUCT_TOKEN   API token for Ainstruct MCP server

On first run, tokens are prompted interactively and saved to a
named Docker volume for subsequent runs. Use --once to skip
persistence entirely (tokens must be provided via environment).

Examples:
  kilo-docker                         # interactive mode
  kilo-docker run "fix build errors"  # autonomous mode
  kilo-docker --once                  # one-time interactive session
  kilo-docker --once run "prompt"     # one-time autonomous session
  kilo-docker init                    # reset and re-enter tokens
  kilo-docker cleanup                 # remove volume, containers, image
  kilo-docker update                  # pull latest image
EOF
    exit 0
fi

# --- Read existing tokens from volume --------------------------------------

TOKEN_1=""
TOKEN_2=""

if [ "$ONCE" -eq 1 ]; then
    # One-time mode: use environment variables only, no volume
    TOKEN_1="${CONTEXT7_TOKEN:-}"
    TOKEN_2="${AINSTRUCT_TOKEN:-}"
else
    FIRST_RUN=0

    EXISTING=""
    if docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        EXISTING=$(docker run --rm --entrypoint "" \
            -v "${DATA_VOLUME}:${DATA_MOUNT}" \
            "$IMAGE" \
            cat "$TOKEN_FILE" 2>/dev/null || true)
    fi

    if [ -z "$EXISTING" ]; then
        FIRST_RUN=1
    else
        TOKEN_1=$(echo "$EXISTING" | grep '^KMCP_TOKEN_1=' | cut -d= -f2- || true)
        TOKEN_2=$(echo "$EXISTING" | grep '^KMCP_TOKEN_2=' | cut -d= -f2- || true)
    fi

    # --- Prompt for missing tokens -------------------------------------------

    # Detect existing env vars as fallback defaults
    ENV_TOKEN_1="${CONTEXT7_TOKEN:-}"
    ENV_TOKEN_2="${AINSTRUCT_TOKEN:-}"

    if [ "$FIRST_RUN" -eq 1 ]; then
        echo "First-time setup: Enter API tokens for remote MCP servers." >&2
        echo "Leave empty to skip a server." >&2
        echo >&2

        if [ -n "$ENV_TOKEN_1" ] || [ -n "$ENV_TOKEN_2" ]; then
            echo "Existing environment variables detected:" >&2
            [ -n "$ENV_TOKEN_1" ] && echo "  - CONTEXT7_TOKEN is set" >&2
            [ -n "$ENV_TOKEN_2" ] && echo "  - AINSTRUCT_TOKEN is set" >&2
            echo "Press Enter to use existing values, or type a new token to override." >&2
            echo >&2
        fi

        if [ -t 1 ]; then
            echo -n "Context7 API token [Enter=use existing]: " >&2
            read -s -r TOKEN_1 </dev/tty
            echo >&2

            echo -n "Ainstruct API token [Enter=use existing]: " >&2
            read -s -r TOKEN_2 </dev/tty
            echo >&2
        else
            echo "No TTY available — using environment variables (if set)." >&2
        fi
        TOKEN_1="${TOKEN_1:-$ENV_TOKEN_1}"
        TOKEN_2="${TOKEN_2:-$ENV_TOKEN_2}"
    fi

    # --- Save tokens to volume -----------------------------------------------

    if [ "$FIRST_RUN" -eq 1 ]; then
        printf 'KMCP_TOKEN_1=%s\nKMCP_TOKEN_2=%s\n' "$TOKEN_1" "$TOKEN_2" | \
            docker run --rm -i --entrypoint "" \
                -v "${DATA_VOLUME}:${DATA_MOUNT}" \
                "$IMAGE" \
                sh -c "cat > '${TOKEN_FILE}'"
    fi
fi

# --- Build docker run args -------------------------------------------------

DOCKER_ARGS=(
    --rm
    --user "${HOST_UID}:${HOST_GID}"
    -v "$(pwd):/workspace"
    -w /workspace
)

if [ "$ONCE" -eq 0 ]; then
    DOCKER_ARGS+=(-v "${DATA_VOLUME}:${DATA_MOUNT}")
fi

if [ -n "$TOKEN_1" ]; then
    DOCKER_ARGS+=(-e "CONTEXT7_TOKEN=${TOKEN_1}")
fi

if [ -n "$TOKEN_2" ]; then
    DOCKER_ARGS+=(-e "AINSTRUCT_TOKEN=${TOKEN_2}")
fi

# --- Run --------------------------------------------------------------------

if [ $# -gt 0 ]; then
    # Autonomous mode: kilo run "prompt"
    exec docker run "${DOCKER_ARGS[@]}" "$IMAGE" "$@"
else
    # Interactive mode
    exec docker run -it "${DOCKER_ARGS[@]}" "$IMAGE"
fi
