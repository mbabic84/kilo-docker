#!/usr/bin/env bash
# kilo-docker — Wrapper script for running Kilo in a Docker container.
#
# Usage: kilo-docker [--once] [--password] [--playwright] [--docker] [--zellij] [--network <name>] [command] [args...]
# See:   kilo-docker help
#
set -euo pipefail

export PATH="/usr/local/bin:/usr/bin:/bin${PATH:+:$PATH}"

readonly REPO="ghcr.io/mbabic84/kilo-docker"
readonly GITHUB_RAW="https://raw.githubusercontent.com/mbabic84/kilo-docker/main/scripts/kilo-docker"
readonly KILO_HOME="/home/kilo-t8x3m7kp"
readonly TOKEN_FILE="${KILO_HOME}/.local/share/kilo/.tokens.env"
readonly ENCRYPTED_TOKEN_FILE="${KILO_HOME}/.local/share/kilo/.tokens.env.enc"
readonly INSTALL_DIR="$HOME/.local/bin"
readonly INSTALL_TARGET="${INSTALL_DIR}/kilo-docker"

# --- Helper functions --------------------------------------------------------

confirm() {
    local prompt="$1"
    local response=""
    echo -n "$prompt" >&2
    if [ -t 2 ]; then
        read -r response </dev/tty || response="n"
    else
        response="n"
        echo "n (no TTY)" >&2
    fi
    [[ "${response,,}" == "y" ]]
}

prompt_password() {
    local skip_confirm="${1:-}"
    local password=""
    while true; do
        echo -n "Password: " >&2
        read -s -r password </dev/tty || { echo >&2; echo "Error: Failed to read password." >&2; exit 1; }
        echo >&2

        if [ -z "$password" ]; then
            echo "Password cannot be empty." >&2
            continue
        fi

        if [ ${#password} -lt 4 ]; then
            echo "Password must be at least 4 characters." >&2
            continue
        fi

        if [ "$skip_confirm" = "skip_confirm" ]; then
            VOLUME_PASSWORD="$password"
            return
        fi

        echo -n "Confirm: " >&2
        local confirm_pw=""
        read -s -r confirm_pw </dev/tty || { echo >&2; echo "Error: Failed to read password." >&2; exit 1; }
        echo >&2

        if [ "$password" = "$confirm_pw" ]; then
            VOLUME_PASSWORD="$password"
            return
        fi
        echo "Passwords do not match. Try again." >&2
        echo >&2
    done
}

confirm_password() {
    local confirm_pw=""
    echo -n "Confirm: " >&2
    read -s -r confirm_pw </dev/tty || { echo >&2; echo "Error: Failed to read password." >&2; exit 1; }
    echo >&2

    if [ "$confirm_pw" = "$VOLUME_PASSWORD" ]; then
        return
    fi

    echo "Passwords do not match. Re-enter password." >&2
    echo >&2
    prompt_password
    derive_volume_name
}

derive_volume_name() {
    local hash
    hash=$(printf '%s' "$VOLUME_PASSWORD" | sha256sum | cut -c1-12)
    DATA_VOLUME="kilo-${hash}"
}

encrypt_tokens() {
    local token1="$1" token2="$2"
    printf 'KMCP_TOKEN_1=%s\nKMCP_TOKEN_2=%s\n' "$token1" "$token2" | \
        openssl enc -aes-256-cbc -salt -pbkdf2 -pass "pass:${VOLUME_PASSWORD}" -out /dev/stdout 2>/dev/null | \
        docker run --rm -i --entrypoint "" \
            -v "${DATA_VOLUME}:${KILO_HOME}" \
            "$IMAGE" \
            sh -c "mkdir -p \"\$(dirname '${ENCRYPTED_TOKEN_FILE}')\" && cat > '${ENCRYPTED_TOKEN_FILE}' && chmod 600 '${ENCRYPTED_TOKEN_FILE}'"
}

decrypt_tokens() {
    local decrypted
    decrypted=$(docker run --rm --entrypoint "" \
        -v "${DATA_VOLUME}:${KILO_HOME}" \
        "$IMAGE" \
        cat "${ENCRYPTED_TOKEN_FILE}" 2>/dev/null | \
        openssl enc -d -aes-256-cbc -pbkdf2 -pass "pass:${VOLUME_PASSWORD}" 2>/dev/null) || return 1
    echo "$decrypted"
}

prompt_new_tokens() {
    local token1="" token2=""

    echo "First-time setup: Enter API tokens for remote MCP servers." >&2
    echo "Leave empty to skip a server." >&2
    echo >&2

    if [ -t 2 ]; then
        echo -n "Context7 API token: " >&2
        read -s -r token1 </dev/tty || true
        echo >&2

        echo -n "Ainstruct API token: " >&2
        read -s -r token2 </dev/tty || true
        echo >&2
    else
        echo "No TTY available. Tokens must be set manually in the volume." >&2
    fi

    if [ -n "$token1" ] || [ -n "$token2" ]; then
        if [ "$ENCRYPTED" -eq 1 ]; then
            echo "Encrypting tokens..." >&2
            encrypt_tokens "$token1" "$token2"
        else
            printf 'KMCP_TOKEN_1=%s\nKMCP_TOKEN_2=%s\n' "$token1" "$token2" | \
                docker run --rm -i --entrypoint "" \
                    -v "${DATA_VOLUME}:${KILO_HOME}" \
                    "$IMAGE" \
                    sh -c "mkdir -p \"\$(dirname '${TOKEN_FILE}')\" && cat > '${TOKEN_FILE}'"
        fi
        TOKEN_1="$token1"
        TOKEN_2="$token2"
    fi
}

# --- Parse flags -------------------------------------------------------------

ONCE=0
ENCRYPTED=0
PLAYWRIGHT=0
DOCKER=0
ZELLIJ=0
NETWORK=""
NETWORK_FLAG=0
FILTERED_ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --once)
            ONCE=1
            ;;
        --password|-p)
            ENCRYPTED=1
            ;;
        --playwright)
            PLAYWRIGHT=1
            ;;
        --docker)
            DOCKER=1
            ;;
        --zellij)
            ZELLIJ=1
            ;;
        --network)
            NETWORK_FLAG=1
            if [ $# -ge 2 ] && [[ "$2" != --* ]]; then
                NETWORK="$2"
                shift
            fi
            ;;
        --network=*)
            NETWORK_FLAG=1
            NETWORK="${1#--network=}"
            ;;
        *)
            FILTERED_ARGS+=("$1")
            ;;
    esac
    shift
done

# Resolve image tag
IMAGE="${REPO}:latest"

# Replace positional parameters with filtered args
set -- "${FILTERED_ARGS[@]}"

# --- Docker socket access ----------------------------------------------------

DOCKER_GID=""
if [ "$DOCKER" -eq 1 ]; then
    if [ ! -S /var/run/docker.sock ]; then
        echo "Error: /var/run/docker.sock not found. Is Docker running?" >&2
        exit 1
    fi

    DOCKER_GID=$(stat -c '%g' /var/run/docker.sock)
fi

# --- Docker daemon check ---------------------------------------------------

if ! docker info >/dev/null 2>&1; then
    echo "Error: Docker daemon is not running." >&2
    exit 1
fi

# --- Handle "help" argument ------------------------------------------------

if [ "${1:-}" = "help" ]; then
    cat >&2 <<'EOF'
Usage: kilo-docker [--once] [--password] [--playwright] [--docker] [--zellij] [--network <name>] [command] [args...]

Commands:
  (no command)      Start Kilo in interactive mode
  run "prompt"      Run Kilo in autonomous mode with a prompt
  networks          List available Docker networks
  backup [-f]       Create backup of volume to tar.gz (auto-names with timestamp)
  restore <file>    Restore volume from backup
  init              Reset configuration (remove volume)
  cleanup           Remove volume, containers, images, and installed script
  install           Install kilo-docker as a global command (~/.local/bin)
  update            Pull the latest Docker image and update the installed script
  update-config     Download latest opencode.json template and merge with existing config
  help              Show this help message (wrapper)

Options:
  --once            Run a one-time session without persisting data (no volume)
  --password, -p    Protect volume with a password (encrypts tokens, derives volume name from password)
  --playwright      Start a Playwright MCP sidecar container for browser automation
  --docker          Mount Docker socket for container management from within Kilo
  --zellij          Run Kilo inside a Zellij session (detach with Ctrl+O D, re-attach with: docker exec -it <c> zellij attach kilo)
  --network <name>  Connect the container to a Docker network

Security (--password):
  When --password is used, the volume name is derived from the password hash,
  making it non-discoverable by other users. API tokens are encrypted with
  AES-256-CBC before being stored in the volume.

  Without --password, the volume name is kilo-data-<username> and tokens are
  stored in plaintext (original behavior).

Security (--docker):
  Mounting the Docker socket grants full Docker API access inside the container.
  This is equivalent to root access on the host. Only use this in trusted
  environments.

Note:
  Use "kilo-docker help" for this wrapper help.
  Use "kilo-docker --help" for Kilo CLI help.

Examples:
  kilo-docker                                    # interactive mode
  kilo-docker run "fix build errors"             # autonomous mode
  kilo-docker --password                         # interactive mode with encryption
  kilo-docker --password init                    # reset encrypted volume
  kilo-docker backup                             # create backup with auto-generated name
  kilo-docker backup -f backup.tar.gz            # create backup with custom name
  kilo-docker restore backup.tar.gz              # restore from backup
  kilo-docker --once                             # one-time interactive session
  kilo-docker --once run "prompt"                # one-time autonomous session
  kilo-docker --playwright                       # with Playwright browser automation
  kilo-docker --docker                           # with Docker socket access
  kilo-docker --zellij                           # run Kilo in a Zellij session
  kilo-docker --network host                     # connect to host network
  kilo-docker networks                           # list available Docker networks
  kilo-docker init                               # reset configuration
  kilo-docker cleanup                            # remove volume, containers, images, script
  kilo-docker install                            # install as global command
  kilo-docker update                             # update script and pull latest image
  kilo-docker update-config                      # update config template, preserve customizations
EOF
    exit 0
fi

# --- Handle "networks" argument ----------------------------------------------

if [ "${1:-}" = "networks" ]; then
    docker network ls --format "{{.Name}}"
    exit 0
fi

# --- Handle "update" argument ----------------------------------------------

if [ "${1:-}" = "update" ]; then
    if [ -f "$INSTALL_TARGET" ]; then
        echo "Updating kilo-docker script..." >&2
        TEMP_FILE="$(mktemp)"
        if curl -fsSL "$GITHUB_RAW" -o "$TEMP_FILE" 2>/dev/null; then
            chmod +x "$TEMP_FILE"
            mv "$TEMP_FILE" "$INSTALL_TARGET"
            echo "Script updated: ${INSTALL_TARGET}" >&2
        else
            rm -f "$TEMP_FILE" 2>/dev/null || true
            echo "Warning: Failed to download script update. Continuing with image pull." >&2
        fi
    else
        echo "kilo-docker script is not installed locally (no file at ${INSTALL_TARGET})." >&2
        echo "Run 'kilo-docker install' to install it first." >&2
    fi

    echo "" >&2
    echo "Pulling Docker image..." >&2
    docker pull "$IMAGE" >&2
    echo "" >&2
    echo "Update complete." >&2
    exit 0
fi

# --- Volume name and password -----------------------------------------------

VOLUME_PASSWORD=""

if [ "$ONCE" -eq 1 ]; then
    # --once: no volume, no password
    DATA_VOLUME=""
elif [ "$ENCRYPTED" -eq 1 ]; then
    # --password: derive volume name from password
    if [ -t 2 ] && [ -t 0 ]; then
        prompt_password skip_confirm
        derive_volume_name
        # If volume doesn't exist yet, confirm the password to avoid typos
        if ! docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
            confirm_password
        fi
    else
        echo "Error: --password requires a TTY. Use --once for ephemeral runs." >&2
        exit 1
    fi
else
    # Default: plaintext volume with username
    DATA_VOLUME="kilo-data-$(whoami)"
fi

# --- Handle "update-config" argument ----------------------------------------

if [ "${1:-}" = "update-config" ]; then
    if [ -z "$DATA_VOLUME" ]; then
        echo "Nothing to update in --once mode." >&2
        exit 0
    fi
    if ! docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        echo "No existing volume found. Run kilo-docker first to create one." >&2
        exit 1
    fi
    echo "Updating opencode.json from repository template..." >&2
    docker run --rm --entrypoint "" \
        -v "${DATA_VOLUME}:${KILO_HOME}" \
        "$IMAGE" \
        sh -c '
            set -e
            TEMPLATE=$(mktemp)
            CONFIG="${HOME}/.config/kilo/opencode.json"
            if curl -fsSL "https://raw.githubusercontent.com/mbabic84/kilo-docker/main/configs/opencode.json" -o "$TEMPLATE"; then
                if [ -f "$CONFIG" ]; then
                    jq -s ".[0] * .[1]" "$TEMPLATE" "$CONFIG" > "${CONFIG}.tmp" && mv "${CONFIG}.tmp" "$CONFIG"
                    echo "Config merged. Existing customizations preserved, new servers added."
                else
                    cp "$TEMPLATE" "$CONFIG"
                    echo "Config created from template."
                fi
            else
                echo "Error: Failed to download config template."
                exit 1
            fi
        '
    exit 0
fi

# --- Handle "init" argument ------------------------------------------------

if [ "${1:-}" = "init" ]; then
    if [ -z "$DATA_VOLUME" ]; then
        echo "Nothing to reset in --once mode." >&2
        exit 0
    fi
    if docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        if confirm "Remove volume '${DATA_VOLUME}' and reset all configuration? [y/N]: "; then
            docker volume rm "$DATA_VOLUME" >/dev/null
            echo "Volume removed. You will be prompted for tokens on next run." >&2
        fi
    else
        if [ "$ENCRYPTED" -eq 1 ]; then
            echo "No existing volume found for this password." >&2
        else
            echo "No existing volume found." >&2
        fi
    fi
    exit 0
fi

# --- Handle "cleanup" argument ----------------------------------------------

if [ "${1:-}" = "cleanup" ]; then
    if ! confirm "Remove volume, containers, and images for kilo-docker? [y/N]: "; then
        echo "Aborted." >&2
        exit 0
    fi

    CONTAINERS=$(docker ps -a --filter "ancestor=${REPO}" -q 2>/dev/null || true)
    if [ -n "$CONTAINERS" ]; then
        echo "Removing containers..." >&2
        echo "$CONTAINERS" | xargs docker rm -f >/dev/null 2>&1 || true
    fi

    if [ -n "$DATA_VOLUME" ] && docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        echo "Removing volume '${DATA_VOLUME}'..." >&2
        docker volume rm "$DATA_VOLUME" >/dev/null
    fi

    local_img="${REPO}:latest"
    if docker image inspect "$local_img" >/dev/null 2>&1; then
        echo "Removing image '${local_img}'..." >&2
        docker rmi "$local_img" >/dev/null
    fi

    if [ -L "$INSTALL_TARGET" ] || [ -f "$INSTALL_TARGET" ]; then
        echo "Removing installed script '${INSTALL_TARGET}'..." >&2
        rm -f "$INSTALL_TARGET"
    fi
    if [ -d "$INSTALL_DIR" ]; then
        rmdir "$INSTALL_DIR" 2>/dev/null || true
    fi

    echo "Cleanup complete." >&2
    exit 0
fi

# --- Handle "backup" argument ----------------------------------------------

if [ "${1:-}" = "backup" ]; then
    shift
    BACKUP_FILE=""
    FORCE_BACKUP=0

    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--force)
                FORCE_BACKUP=1
                ;;
            -*)
                echo "Unknown option: $1" >&2
                exit 1
                ;;
            *)
                BACKUP_FILE="$1"
                ;;
        esac
        shift
    done

    if [ -z "$DATA_VOLUME" ]; then
        echo "Error: backup is not available in --once mode." >&2
        exit 1
    fi

    if ! docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        echo "Error: volume '${DATA_VOLUME}' does not exist." >&2
        exit 1
    fi

    if [ -z "$BACKUP_FILE" ]; then
        TIMESTAMP=$(date +%Y%m%d-%H%M%S)
        if [ "$ENCRYPTED" -eq 1 ]; then
            BACKUP_FILE="kilo-backup-${TIMESTAMP}.tar.gz.enc"
        else
            BACKUP_FILE="kilo-backup-${TIMESTAMP}.tar.gz"
        fi
    fi

    if [ -f "$BACKUP_FILE" ] && [ "$FORCE_BACKUP" -eq 0 ]; then
        if ! confirm "Backup file '${BACKUP_FILE}' exists. Overwrite? [y/N]: "; then
            echo "Aborted." >&2
            exit 0
        fi
    fi

    echo "Creating backup of volume '${DATA_VOLUME}' to '${BACKUP_FILE}'..." >&2

    TEMP_DIR=$(mktemp -d)
    TEMP_CONTAINER="kilo-backup-temp-$$"
    docker run --rm -d --name "$TEMP_CONTAINER" -v "${DATA_VOLUME}:/src:ro" alpine:latest tail -f /dev/null >/dev/null 2>&1
    sleep 0.5
    docker cp "$TEMP_CONTAINER:/src/." "$TEMP_DIR/src" 2>/dev/null
    docker rm -f "$TEMP_CONTAINER" >/dev/null 2>&1
    tar czf "${BACKUP_FILE}" -C "$TEMP_DIR/src" .
    rm -rf "$TEMP_DIR"

    if [ "$ENCRYPTED" -eq 1 ]; then
        echo "Backup created (encrypted): ${BACKUP_FILE}" >&2
    else
        echo "Backup created: ${BACKUP_FILE}" >&2
    fi
    exit 0
fi

# --- Handle "restore" argument ----------------------------------------------

if [ "${1:-}" = "restore" ]; then
    shift
    BACKUP_FILE=""
    FORCE_RESTORE=0

    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--force)
                FORCE_RESTORE=1
                ;;
            -*)
                echo "Unknown option: $1" >&2
                exit 1
                ;;
            *)
                BACKUP_FILE="$1"
                ;;
        esac
        shift
    done

    if [ -z "$DATA_VOLUME" ]; then
        echo "Error: restore is not available in --once mode." >&2
        exit 1
    fi

    if [ -z "$BACKUP_FILE" ]; then
        echo "Error: backup file path required." >&2
        echo "Usage: kilo-docker restore <backup-file> [-f]" >&2
        exit 1
    fi

    if [ ! -f "$BACKUP_FILE" ]; then
        echo "Error: backup file '${BACKUP_FILE}' not found." >&2
        exit 1
    fi

    if ! tar -tzf "$BACKUP_FILE" >/dev/null 2>&1; then
        echo "Error: invalid or corrupted backup file." >&2
        exit 1
    fi

    if docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        if [ "$FORCE_RESTORE" -eq 0 ]; then
            if ! confirm "Volume '${DATA_VOLUME}' exists and will be overwritten. Continue? [y/N]: "; then
                echo "Aborted." >&2
                exit 0
            fi
        fi
        docker volume rm "$DATA_VOLUME" >/dev/null 2>&1 || true
    fi

    echo "Restoring backup '${BACKUP_FILE}' to volume '${DATA_VOLUME}'..." >&2

    docker volume create "$DATA_VOLUME" >/dev/null

    if ! tar -xzf "$BACKUP_FILE" -C "$(docker run --rm -v "${DATA_VOLUME}:/dest" alpine echo /dest)" 2>/dev/null; then
        docker run --rm -v "${DATA_VOLUME}:/dest" -v "$(dirname "$BACKUP_FILE"):/backup:ro" alpine \
            tar xzf /backup/"$(basename "$BACKUP_FILE")" -C /dest
    fi

    docker run --rm -v "${DATA_VOLUME}:/dest" alpine chown -R 1000:1000 /dest 2>/dev/null || true

    echo "Restore complete." >&2
    exit 0
fi

# --- Handle "install" argument -----------------------------------------------

if [ "${1:-}" = "install" ]; then
    SOURCE_SCRIPT=""

    if [ -f "$0" ]; then
        SOURCE_SCRIPT="$(realpath "$0")"
    fi

    DOWNLOADED_SCRIPT=""

    if [ -z "$SOURCE_SCRIPT" ] || [ ! -f "$SOURCE_SCRIPT" ]; then
        echo "Source script path not available (e.g., running via pipe). Downloading..." >&2
        DOWNLOADED_SCRIPT="$(mktemp)"
        if curl -fsSL "$GITHUB_RAW" -o "$DOWNLOADED_SCRIPT" 2>/dev/null; then
            chmod +x "$DOWNLOADED_SCRIPT"
            SOURCE_SCRIPT="$DOWNLOADED_SCRIPT"
        else
            echo "Error: Failed to download script from ${GITHUB_RAW}." >&2
            exit 1
        fi
    fi

    mkdir -p "$INSTALL_DIR"

    if [ -n "$DOWNLOADED_SCRIPT" ]; then
        cp "$SOURCE_SCRIPT" "$INSTALL_TARGET"
        rm -f "$DOWNLOADED_SCRIPT"
    elif [ -L "$INSTALL_TARGET" ]; then
        echo "kilo-docker is already installed at ${INSTALL_TARGET}" >&2
        echo "Updating symlink..." >&2
        ln -sf "$SOURCE_SCRIPT" "$INSTALL_TARGET"
    elif [ -f "$INSTALL_TARGET" ]; then
        echo "kilo-docker already exists at ${INSTALL_TARGET} (not a symlink)." >&2
        if confirm "Replace it? [y/N]: "; then
            ln -sf "$SOURCE_SCRIPT" "$INSTALL_TARGET"
        else
            echo "Aborted." >&2
            exit 0
        fi
    else
        ln -s "$SOURCE_SCRIPT" "$INSTALL_TARGET" 2>/dev/null || {
            echo "Symlink failed (cross-device?). Copying instead..." >&2
            cp "$SOURCE_SCRIPT" "$INSTALL_TARGET"
        }
    fi

    chmod +x "$INSTALL_TARGET"

    case ":${PATH}:" in
        *":${INSTALL_DIR}:"*)
            ;;
        *)
            echo "" >&2
            echo "Warning: ${INSTALL_DIR} is not on your PATH." >&2
            if [ -f "$HOME/.profile" ] && grep -q '.local/bin' "$HOME/.profile"; then
                echo "Your ~/.profile already configures ~/.local/bin for PATH, but it was not active at login." >&2
                echo "Run one of the following to activate it:" >&2
                echo '  source ~/.profile' >&2
                echo "Or log out and log back in." >&2
            else
                echo "Add the following line to your ~/.bashrc (or ~/.zshrc):" >&2
                echo "  export PATH=\"\$HOME/.local/bin:\$PATH\"" >&2
                echo "Then restart your shell or run: source ~/.bashrc" >&2
            fi
            ;;
    esac

    echo "" >&2
    echo "Pulling Docker image..." >&2
    docker pull "$IMAGE" >&2
    echo "" >&2
    echo "Installed successfully: ${INSTALL_TARGET} -> ${SOURCE_SCRIPT}" >&2
    echo "Run 'kilo-docker' from any directory." >&2
    exit 0
fi

# --- Interactive network selection -------------------------------------------

if [ "$NETWORK_FLAG" -eq 1 ] && [ -z "$NETWORK" ] && [ -t 0 ] && [ -t 2 ]; then
    if mapfile -t AVAILABLE_NETWORKS < <(docker network ls --format "{{.Name}}" 2>/dev/null) && [ ${#AVAILABLE_NETWORKS[@]} -gt 0 ]; then
        echo "Available Docker networks:" >&2
        for i in "${!AVAILABLE_NETWORKS[@]}"; do
            echo "  $((i + 1)). ${AVAILABLE_NETWORKS[$i]}" >&2
        done
        echo -n "Select a network (number) or press Enter to use default: " >&2
        local_selection=""
        read -r local_selection </dev/tty || local_selection=""
        if [ -n "$local_selection" ]; then
            if [[ "$local_selection" =~ ^[0-9]+$ ]] && [ "$local_selection" -ge 1 ] && [ "$local_selection" -le ${#AVAILABLE_NETWORKS[@]} ]; then
                NETWORK="${AVAILABLE_NETWORKS[$((local_selection - 1))]}"
                echo "Using network: ${NETWORK}" >&2
            else
                echo "Invalid selection. Using default network." >&2
            fi
        fi
    fi
fi

# --- Read/load tokens -------------------------------------------------------

TOKEN_1=""
TOKEN_2=""

if [ "$ONCE" -eq 0 ]; then
    if docker volume inspect "$DATA_VOLUME" >/dev/null 2>&1; then
        if [ "$ENCRYPTED" -eq 1 ]; then
            # Encrypted mode: decrypt existing tokens
            DECRYPTED=$(decrypt_tokens) || true

            if [ -n "$DECRYPTED" ]; then
                TOKEN_1=$(echo "$DECRYPTED" | grep '^KMCP_TOKEN_1=' | cut -d= -f2- || true)
                TOKEN_2=$(echo "$DECRYPTED" | grep '^KMCP_TOKEN_2=' | cut -d= -f2- || true)
            fi

            if [ -z "$TOKEN_1" ] && [ -z "$TOKEN_2" ]; then
                # Check if old plaintext token file exists (migration)
                PLAINTEXT=$(docker run --rm --entrypoint "" \
                    -v "${DATA_VOLUME}:${KILO_HOME}" \
                    "$IMAGE" \
                    cat "$TOKEN_FILE" 2>/dev/null || true)

                if [ -n "$PLAINTEXT" ]; then
                    echo "Migrating plaintext tokens to encrypted storage..." >&2
                    TOKEN_1=$(echo "$PLAINTEXT" | grep '^KMCP_TOKEN_1=' | cut -d= -f2- || true)
                    TOKEN_2=$(echo "$PLAINTEXT" | grep '^KMCP_TOKEN_2=' | cut -d= -f2- || true)

                    if [ -n "$TOKEN_1" ] || [ -n "$TOKEN_2" ]; then
                        encrypt_tokens "$TOKEN_1" "$TOKEN_2"
                        # Remove old plaintext file
                        docker run --rm --entrypoint "" \
                            -v "${DATA_VOLUME}:${KILO_HOME}" \
                            "$IMAGE" \
                            rm -f "$TOKEN_FILE" 2>/dev/null || true
                        echo "Migration complete. Old plaintext token file removed." >&2
                    fi
                fi
            fi
        else
            # Plaintext mode: read tokens directly
            EXISTING=$(docker run --rm --entrypoint "" \
                -v "${DATA_VOLUME}:${KILO_HOME}" \
                "$IMAGE" \
                cat "$TOKEN_FILE" 2>/dev/null || true)

            if [ -n "$EXISTING" ]; then
                TOKEN_1=$(echo "$EXISTING" | grep '^KMCP_TOKEN_1=' | cut -d= -f2- || true)
                TOKEN_2=$(echo "$EXISTING" | grep '^KMCP_TOKEN_2=' | cut -d= -f2- || true)
            fi
        fi
    fi

    # If still no tokens, prompt for new ones
    if [ -z "$TOKEN_1" ] && [ -z "$TOKEN_2" ]; then
        prompt_new_tokens
    fi
fi

# --- Playwright sidecar ----------------------------------------------------

PLAYWRIGHT_IMAGE="mcr.microsoft.com/playwright/mcp"
PLAYWRIGHT_NETWORK=""
PLAYWRIGHT_CONTAINER="playwright-mcp"

if [ "$PLAYWRIGHT" -eq 1 ]; then
    if [ -n "$NETWORK" ]; then
        echo "Error: --playwright and --network are mutually exclusive." >&2
        echo "       Playwright creates its own network." >&2
        exit 1
    fi

    PLAYWRIGHT_NETWORK="kilo-playwright-$(whoami)"

    # Create network (idempotent)
    if ! docker network inspect "$PLAYWRIGHT_NETWORK" >/dev/null 2>&1; then
        docker network create "$PLAYWRIGHT_NETWORK" >/dev/null
    fi

    # Pull Playwright MCP image
    echo "Pulling Playwright MCP image..." >&2
    docker pull "$PLAYWRIGHT_IMAGE" >/dev/null 2>&1

    # Ensure output directory exists
    mkdir -p "$(pwd)/.playwright-mcp"

    # Remove any stale container
    docker rm -f "$PLAYWRIGHT_CONTAINER" >/dev/null 2>&1 || true

    # Start Playwright MCP in HTTP mode.
    # Uses --entrypoint node (overrides default entrypoint) with cli.js
    # relative to image WORKDIR /app.
    docker run -d --rm --init \
        --name "$PLAYWRIGHT_CONTAINER" \
        --network "$PLAYWRIGHT_NETWORK" \
        --entrypoint node \
        -v "$(pwd):/mnt/$(basename "$(pwd)")" \
        "$PLAYWRIGHT_IMAGE" \
        cli.js --headless --browser chromium --no-sandbox --port 8931 --host 0.0.0.0 --output-dir "/mnt/$(basename "$(pwd)")/.playwright-mcp" --allowed-hosts '*' \
        >/dev/null

    # Wait for Playwright MCP to be ready
    echo -n "Waiting for Playwright MCP..." >&2
    for i in $(seq 1 30); do
        # Check container is still running
        if [ "$(docker inspect -f '{{.State.Status}}' "$PLAYWRIGHT_CONTAINER" 2>/dev/null)" != "running" ]; then
            echo " container stopped." >&2
            echo "Error: Playwright MCP container exited unexpectedly." >&2
            docker logs "$PLAYWRIGHT_CONTAINER" 2>&1 | tail -5 >&2
            docker rm -f "$PLAYWRIGHT_CONTAINER" >/dev/null 2>&1 || true
            docker network rm "$PLAYWRIGHT_NETWORK" >/dev/null 2>&1 || true
            exit 1
        fi
        # Check if port 8931 is listening (MCP endpoint rejects plain GET, so use TCP check)
        if docker exec "$PLAYWRIGHT_CONTAINER" node -e "
            const net = require('net');
            const s = net.connect(8931, '127.0.0.1', () => { s.destroy(); process.exit(0); });
            s.on('error', () => process.exit(1));
            s.setTimeout(2000, () => { s.destroy(); process.exit(1); });
        " 2>/dev/null; then
            echo " ready." >&2
            break
        fi
        if [ "$i" -eq 30 ]; then
            echo " timeout." >&2
            echo "Error: Playwright MCP did not become ready in 30s." >&2
            docker logs "$PLAYWRIGHT_CONTAINER" 2>&1 | tail -5 >&2
            docker rm -f "$PLAYWRIGHT_CONTAINER" >/dev/null 2>&1 || true
            docker network rm "$PLAYWRIGHT_NETWORK" >/dev/null 2>&1 || true
            exit 1
        fi
        sleep 1
        echo -n "." >&2
    done

    # Cleanup function called on EXIT (fires after exec'd docker run exits)
    cleanup_playwright() {
        docker rm -f "$PLAYWRIGHT_CONTAINER" >/dev/null 2>&1 || true
        docker network rm "$PLAYWRIGHT_NETWORK" >/dev/null 2>&1 || true
    }
    trap cleanup_playwright EXIT

    # Use the Playwright network for the Kilo container
    NETWORK="$PLAYWRIGHT_NETWORK"
fi

# --- Workspace path conflict check ----------------------------------------

CURRENT_PWD="$(pwd)"
if [ -z "$ONCE" ] || [ "$ONCE" -eq 0 ]; then
    case "$CURRENT_PWD" in
        "/home/kilo-t8x3m7kp"|"/home/kilo-t8x3m7kp"/*)
            echo "Warning: Current directory (${CURRENT_PWD}) overlaps with the container's home path." >&2
            echo "This may cause permission issues or unexpected behavior." >&2
            ;;
    esac
fi

# --- Build docker run args -------------------------------------------------

DOCKER_ARGS=(
    --rm
    --init
    --ipc=host
    -e "PUID=$(id -u)"
    -e "PGID=$(id -g)"
    -v "${CURRENT_PWD}:${CURRENT_PWD}"
    -w "${CURRENT_PWD}"
)

if [ "$ONCE" -eq 0 ] && [ -n "$DATA_VOLUME" ]; then
    DOCKER_ARGS+=(-v "${DATA_VOLUME}:${KILO_HOME}")
fi

if [ -n "$TOKEN_1" ]; then
    DOCKER_ARGS+=(-e "CONTEXT7_TOKEN=${TOKEN_1}")
fi

if [ -n "$TOKEN_2" ]; then
    DOCKER_ARGS+=(-e "AINSTRUCT_TOKEN=${TOKEN_2}")
fi

if [ "$PLAYWRIGHT" -eq 1 ]; then
    DOCKER_ARGS+=(-e "PLAYWRIGHT_ENABLED=1")
fi

if [ "$DOCKER" -eq 1 ]; then
    DOCKER_ARGS+=(-v /var/run/docker.sock:/var/run/docker.sock)
    DOCKER_ARGS+=(-e "DOCKER_ENABLED=1")
    DOCKER_ARGS+=(-e "DOCKER_GID=${DOCKER_GID}")
fi

if [ "$ZELLIJ" -eq 1 ]; then
    DOCKER_ARGS+=(-e "ZELLIJ=1")
fi

if [ -n "$NETWORK" ]; then
    DOCKER_ARGS+=(--network "$NETWORK")
fi

# Pass terminal capability variables
for var in TERM COLORTERM LANG LC_ALL; do
    if [ -n "${!var:-}" ]; then
        DOCKER_ARGS+=(-e "${var}=${!var}")
    fi
done

# --- Clear sensitive data from shell ----------------------------------------

unset VOLUME_PASSWORD 2>/dev/null || true

# --- Run --------------------------------------------------------------------

if [ $# -gt 0 ]; then
    if [ -t 0 ]; then
        exec docker run -it "${DOCKER_ARGS[@]}" "$IMAGE" "$@"
    else
        exec docker run "${DOCKER_ARGS[@]}" "$IMAGE" "$@"
    fi
else
    if [ -t 0 ]; then
        exec docker run -it "${DOCKER_ARGS[@]}" "$IMAGE"
    else
        exec docker run -i "${DOCKER_ARGS[@]}" "$IMAGE"
    fi
fi
