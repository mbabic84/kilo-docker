{
  "$schema": "https://app.kilo.ai/config.json",
  "autoupdate": "notify",
  "mcp": {
    "ainstruct": {
      "type": "remote",
      "url": "https://ainstruct-dev.kralicinora.cz/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:AINSTRUCT_TOKEN}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:CONTEXT7_TOKEN}"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--no-sandbox"],
      "enabled": true
    }
  },
  "instructions": [
    "~/.config/kilo/rules/*.md"
  ],
  "permission": {
    "ainstruct_*": "allow",
    "context7_*": "allow",
    "playwright_*": "allow"
  }
}
