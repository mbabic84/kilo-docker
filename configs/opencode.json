{
  "$schema": "https://app.kilo.ai/config.json",
  "autoupdate": "notify",
  "mcp": {
    "ainstruct": {
      "type": "remote",
      "url": "https://ainstruct-dev.kralicinora.cz/mcp",
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:AINSTRUCT_TOKEN}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:CONTEXT7_TOKEN}"
      }
    },
    "playwright": {
      "type": "remote",
      "url": "http://playwright-mcp:8931/mcp",
      "enabled": false
    }
  },
  "instructions": [
    "~/.config/kilo/rules/*.md"
  ],
  "permission": {
    "ainstruct_*": "allow",
    "context7_*": "allow",
    "playwright_*": "allow"
  }
}
